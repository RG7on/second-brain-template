#!/usr/bin/env python3
"""brain — toolbelt for the second-brain repo. Python stdlib only, no dependencies.

Commands:
  brain init                       wire a fresh clone into Claude (run once)
  brain new <kind> "<title>" [--topics a,b] [--sensitivity normal|personal]
  brain capture "<text>" [--commit]  quick note into knowledge/inbox/
  brain lint [--staged]            validate every note; exit 1 on errors
  brain search "<query>" [--scope all] [--limit N] [--json]
  brain read <id-or-path>          full note with supersede chain resolved
  brain links <id-or-path> [--json]  wikilink graph: what links here, what it links to
  brain supersede <old-id> "<new title>"   full supersede choreography in one shot
  brain recent [--days N]          recently touched notes
  brain index [--quiet]            rebuild the FTS5 search index (.cache/)
  brain sessions [--days N] [--stdout]   digest own turns from recent Claude
                                   sessions into .cache/ (never committed)
  brain consolidate [--dry-run]    weekly tidy pass via Claude, lands on a branch
  brain schedule install|uninstall|status [--with-consolidate]
  brain template <dest> [--force]  emit a publishable copy: all tooling, none
                                   of your notes (the public template is DERIVED)
  brain doctor                     health report (hooks, backup, lint, tools)

Lint exit codes: 0 = clean, 1 = content errors (block commit), 3 = environment
failure (the pre-commit hook fails OPEN on 3 so a broken toolchain never blocks
capture).
"""
from __future__ import annotations

import re
import subprocess
import sys
import time
from datetime import date
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
K = ROOT / "knowledge"

CANONICAL = ("decisions", "topics", "projects", "people", "life", "reference")
FOLDER_KIND = {
    "decisions": "decision",
    "topics": "topic",
    "projects": "project",
    "people": "person",
    "life": "note",
    "reference": "reference",
}
STATUSES = {"current", "superseded", "draft"}
SENSITIVITIES = {"normal", "personal", "private"}
SENSITIVITY_REQUIRED = {"people", "life"}

DATE_RE = re.compile(r"^\d{4}-\d{2}-\d{2}$")
ID_RE = re.compile(r"^[a-z0-9][a-z0-9-]{2,79}$")
DECISION_FILE_RE = re.compile(r"^\d{4}-\d{2}-\d{2}-[a-z0-9-]+\.md$")
RELATIVE_DATES = re.compile(
    r"(?i)\b(yesterday|tomorrow|last (?:week|month|year)|next (?:week|month|year))\b"
)
EXEMPT_NAMES = {"index.md", "README.md"}
MAX_INDEX_LINES = 200
MAX_FILE_BYTES = 1_000_000
ALLOW_PRAGMA = "lint:allow-secret"

SECRET_PATTERNS = [
    ("private key block", re.compile(r"-----BEGIN [A-Z ]*PRIVATE KEY-----")),
    ("AWS access key id", re.compile(r"\bAKIA[0-9A-Z]{16}\b")),
    ("GitHub classic token", re.compile(r"\bgh[pousr]_[A-Za-z0-9]{36,}\b")),
    ("GitHub fine-grained PAT", re.compile(r"\bgithub_pat_[A-Za-z0-9_]{22,}\b")),
    ("Slack token", re.compile(r"\bxox[bpars]-[A-Za-z0-9-]{10,}\b")),
    # Anthropic/OpenAI-style keys: sk-... AND Stripe/other sk_live_/sk_test_...
    ("API-style key", re.compile(r"\bsk-[A-Za-z0-9_-]{20,}\b")),
    ("Stripe secret key", re.compile(r"\bsk_(?:live|test)_[A-Za-z0-9]{16,}\b")),
    ("Stripe restricted key", re.compile(r"\brk_(?:live|test)_[A-Za-z0-9]{16,}\b")),
    ("Google API key", re.compile(r"\bAIza[0-9A-Za-z_\-]{20,}\b")),
    ("Google OAuth id", re.compile(r"\b[0-9]+-[0-9a-z]{32}\.apps\.googleusercontent\.com\b")),
    ("JWT", re.compile(r"\beyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\b")),
    # A connection URL carrying an inline credential (the user-colon-secret pair
    # before the host). Covers postgres, mongodb, redis, amqp, https, etc. The
    # example forms are kept out of this comment on purpose — this scanner scans
    # its own source, and a literal sample here would self-flag.
    ("URL with embedded credentials",
     re.compile(r"\b[a-z][a-z0-9+.\-]*://[^\s:/@]+:[^\s/@]{4,}@")),
    # An assignment of a secret-ish name to a long opaque value. Unlike the old
    # rule this does NOT require the value to be quoted — the real leak that got
    # through was `STRIPE_SECRET_KEY=sk_live_…` and `aws_secret_access_key=…`
    # with bare values. Prose ("the password: see the runbook") is safe: the
    # value run must be 12+ non-space chars with no spaces.
    (
        "credential assignment",
        re.compile(r"(?i)\b(?:aws_secret_access_key|secret[_-]?access[_-]?key|"
                   r"client[_-]?secret|access[_-]?token|auth[_-]?token|refresh[_-]?token|"
                   r"api[_-]?key|secret[_-]?key|private[_-]?key|secret|token|passwd|password)\b"
                   r"\s*[:=]\s*['\"]?[^'\"\s]{12,}"),
    ),
]


def slugify(text: str) -> str:
    slug = re.sub(r"[^a-z0-9]+", "-", text.lower()).strip("-")
    return slug[:60] or "untitled"


def _split_list(inner: str) -> list:
    """Split an inline [a, b] list on commas, respecting quotes — so
    ["brain, ai-tooling"] is ONE item, matching what a real YAML reader sees."""
    items, cur, quote = [], "", None
    for ch in inner:
        if quote:
            if ch == quote:
                quote = None
            else:
                cur += ch
        elif ch in "'\"":
            quote = ch
        elif ch == ",":
            items.append(cur.strip())
            cur = ""
        else:
            cur += ch
    items.append(cur.strip())
    return [i for i in items if i]


def parse_frontmatter(text: str):
    """Parse the restricted frontmatter subset: flat 'key: value', inline [lists].

    Returns (dict, None) on success, (None, error_message) on failure.
    """
    lines = text.splitlines()
    if not lines or lines[0].strip() != "---":
        return None, "missing frontmatter (file must start with ---)"
    fm = {}
    for i, line in enumerate(lines[1:], start=2):
        if line.strip() == "---":
            fm["_end_line"] = i
            return fm, None
        if not line.strip() or line.lstrip().startswith("#"):
            continue
        m = re.match(r"^([A-Za-z_][A-Za-z0-9_]*):\s*(.*)$", line)
        if not m:
            return None, f"line {i}: cannot parse {line.strip()!r} (only flat 'key: value' allowed)"
        key, raw = m.group(1), m.group(2).strip()
        if key in fm:
            return None, f"line {i}: duplicate frontmatter key {key!r}"
        if raw.startswith("[") and raw.endswith("]"):
            fm[key] = _split_list(raw[1:-1].strip())
        elif raw in ("", "null", "~"):
            fm[key] = None
        else:
            fm[key] = raw.strip("'\"")
    return None, "frontmatter never closed with a second ---"


def load_topics() -> dict:
    path = K / "topics.yaml"
    topics = {}
    if not path.exists():
        return topics
    for line in path.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        m = re.match(r"^([a-z0-9-]+):\s*(.*)$", line)
        if m:
            topics[m.group(1)] = [a.strip() for a in m.group(2).split(",") if a.strip()]
    return topics


def read_text(path: Path) -> str:
    # utf-8-sig: transparently strips a Windows BOM so a BOM'd note still
    # starts with "---" as far as the parser is concerned.
    return path.read_text(encoding="utf-8-sig", errors="replace")


def valid_date(value) -> bool:
    try:
        date.fromisoformat(str(value))
        return True
    except ValueError:
        return False


def git(*args: str, check: bool = False) -> str:
    result = subprocess.run(
        ["git", *args], cwd=ROOT, capture_output=True, text=True, check=check
    )
    return result.stdout.strip()


class repo_lock:
    """Serialize git-index mutations across concurrent brain processes.

    Every Claude session runs its own MCP server, so two `capture --commit`
    calls can fire at the same instant. They used to race on .git/index: one
    commit swept in the other's staged file (committed under the wrong
    message) and left notes uncommitted while telling the caller they were
    saved. An exclusive advisory lock elects one writer at a time. Non-POSIX
    platforms fall back to no lock (best-effort), same as the index builder."""

    def __enter__(self):
        (ROOT / ".cache").mkdir(exist_ok=True)
        self._lf = open(ROOT / ".cache" / "git.lock", "w")
        try:
            import fcntl
            fcntl.flock(self._lf, fcntl.LOCK_EX)
        except ImportError:
            pass
        return self

    def __exit__(self, *exc):
        try:
            self._lf.close()
        except Exception:
            pass
        return False


def is_local_remote(url: str) -> bool:
    """Is this 'remote' just a path on this machine?

    `git clone ~/brain` sets origin to the source repo, so the auto-push hook
    would push a scratch copy's commits — throwaway branches included — back
    into the real brain. Mirrors the same test in .githooks/post-commit; keep
    the two in step."""
    url = (url or "").strip()
    if not url:
        return False
    path = url[len("file://"):] if url.startswith("file://") else url
    if url.startswith(("file://", "/", "./", "../", "~")):
        return True
    if Path(path).is_dir():
        return True
    if "://" in url:
        return False                      # https://, ssh://, git://
    return ":" not in url                 # scp-style git@host:owner/repo is remote


def ensure_hooks() -> None:
    try:
        if git("config", "core.hooksPath") != ".githooks":
            subprocess.run(
                ["git", "config", "core.hooksPath", ".githooks"], cwd=ROOT, check=False
            )
            print("brain: installed git hooks (core.hooksPath = .githooks)")
    except Exception:
        pass


# Literal screen: a substring EVERY secret pattern must contain to match.
# Each regex above begins with \b, which forces the engine to try at every
# position — ~165ms per pattern over a 30MB corpus, so 13 of them cost ~2.2s on
# every lint. str.__contains__ uses a C substring search and is ~10x cheaper, so
# a file is only handed to the regexes when a required literal is actually
# present. These lists must stay a strict SUPERSET of the patterns: if you add a
# pattern above, add the literal it cannot match without.
SECRET_LITERALS = (
    "PRIVATE KEY",                                    # private key block
    "AKIA",                                           # AWS access key id
    "ghp_", "gho_", "ghu_", "ghs_", "ghr_",           # GitHub classic
    "github_pat_",                                    # GitHub fine-grained
    "xox",                                            # Slack
    "sk-", "sk_", "rk_",                              # OpenAI/Anthropic, Stripe
    "AIza", ".apps.googleusercontent.com",            # Google
    "eyJ",                                            # JWT
    "://",                                            # URL with inline credential
)
# The credential-assignment rule is case-insensitive; these are matched against
# a lowercased copy. "secret" also covers client_secret/secret_key/
# aws_secret_access_key; "token" covers access_/auth_/refresh_token.
SECRET_KEYWORDS = (
    "secret", "token", "passwd", "password",
    "apikey", "api_key", "api-key",
    "privatekey", "private_key", "private-key",
)


def secret_screen(text: str) -> bool:
    """True if any secret pattern could possibly match — cheap superset test."""
    for literal in SECRET_LITERALS:
        if literal in text:
            return True
    lowered = text.lower()
    for keyword in SECRET_KEYWORDS:
        if keyword in lowered:
            return True
    return False


def scan_secrets(path: Path, errors: list, raw: bytes = None) -> None:
    """Scan a file for secret patterns. Bytes-aware: UTF-16 content (NUL-interleaved
    when read as UTF-8) is decoded and scanned too, so encoding is not an evasion."""
    if raw is None:
        try:
            raw = path.read_bytes()
        except OSError as exc:
            errors.append((path, f"unreadable file: {exc}"))
            return
    texts = [raw.decode("utf-8-sig", errors="replace")]
    if b"\x00" in raw[:4096]:
        for enc in ("utf-16", "utf-16-le", "utf-16-be"):
            try:
                texts.append(raw.decode(enc))
                break
            except (UnicodeDecodeError, ValueError):
                continue
    for text in texts:
        if not secret_screen(text):
            continue
        for lineno, line in enumerate(text.splitlines(), start=1):
            if ALLOW_PRAGMA in line:
                continue
            for label, pattern in SECRET_PATTERNS:
                if pattern.search(line):
                    errors.append((path, f"line {lineno}: possible {label} — secrets never "
                                   "go in this repo"))


def scan_conflicts(path: Path, errors: list, text: str = None) -> None:
    """Flag unresolved git merge-conflict markers. Two machines editing the same
    note produce '<<<<<<<'/'>>>>>>>' hunks; committed unresolved, both
    contradictory claims live inside one note and are served as one current
    fact. Requiring BOTH the start and end marker avoids false-flagging a
    markdown setext heading underline (a line of '=' characters)."""
    if text is None:
        try:
            text = path.read_text(encoding="utf-8-sig", errors="replace")
        except OSError:
            return
    lines = text.splitlines()
    start = next((i + 1 for i, l in enumerate(lines) if l.startswith("<<<<<<< ")), None)
    has_end = any(l.startswith(">>>>>>> ") for l in lines)
    if start and has_end:
        errors.append((path, f"line {start}: unresolved merge-conflict markers — resolve the "
                       "conflict before committing; both claims are otherwise served as one note"))


def collect_notes():
    """Return {relpath: (fm_or_None, parse_error_or_None)} for every markdown note
    under knowledge/, matched case-insensitively (Foo.MD is still a note)."""
    notes = {}
    for path in sorted(K.rglob("*")):
        if path.is_file() and path.suffix.lower() == ".md":
            notes[path.relative_to(K)] = parse_frontmatter(read_text(path))
    return notes


class LintCtx:
    """Everything the checkers accumulate into or consult.

    Lifting these out of lint()'s closure is what lets the commit gate reuse the
    exact same checks against blobs read from the git index instead of files
    read from disk — one implementation, two sources, no second rulebook that
    can drift out of step with the first."""

    def __init__(self, topics: dict, metas: dict):
        self.errors: list = []
        self.warnings: list = []
        self.topics = topics
        self.metas = metas


class Blob:
    """One file's bytes, from the working tree or from the git index."""

    def __init__(self, raw: bytes, is_symlink: bool = False):
        self.raw = raw
        self.is_symlink = is_symlink

    def text(self) -> str:
        return self.raw.decode("utf-8-sig", errors="replace")

    @classmethod
    def from_disk(cls, path: Path):
        if path.is_symlink():
            return cls(b"", is_symlink=True)
        return cls(path.read_bytes())


def check_links(path, text, fm, ctx: LintCtx, hard: bool = True) -> None:
    """Validate every [[wikilink]] in a body against the real note set.

    Unvalidated links are how a knowledge base rots silently: supersede
    moves a note to archive/, and every hub page still pointing at the old
    id keeps serving superseded knowledge as current. `hard` is False for
    provisional material (inbox/journal), where a dangling link must not
    block a commit. Archived notes are never checked — they are append-only
    history and their links cannot be repaired.
    """
    start = (fm or {}).get("_end_line", 0)
    body = "\n".join(text.splitlines()[start:])
    # A successor legitimately cites the note it replaced ("Supersedes
    # [[old-id]]" is exactly what the supersede protocol writes), so that
    # one back-reference is never stale.
    predecessor = (fm or {}).get("supersedes")
    for target in extract_links(body):
        if target not in ctx.metas:
            bucket = ctx.errors if hard else ctx.warnings
            bucket.append((path, f"dangling wikilink [[{target}]] — no note has that id "
                           "(typo, or the note was deleted rather than superseded)"))
            continue
        if target == predecessor:
            continue
        t_rel, t_fm = ctx.metas[target]
        if t_rel.parts[0] == "archive":
            successor = t_fm.get("superseded_by")
            ctx.warnings.append((path, f"wikilink [[{target}]] points at a SUPERSEDED note"
                                 + (f" — repoint it at [[{successor}]]" if successor else
                                    " with no recorded successor")))


def check_note(path, rel, folder, in_archive, fm, text, ctx: LintCtx):
    errors, warnings, topics, metas = ctx.errors, ctx.warnings, ctx.topics, ctx.metas
    for f in ("id", "kind", "title", "created", "status", "sensitivity",
              "supersedes", "superseded_by", "valid_from", "review_by"):
        if isinstance(fm.get(f), list):
            errors.append((path, f"{f} must be a single value, not a list"))
            fm[f] = None

    for field in ("id", "kind", "title", "topics", "created", "status"):
        if fm.get(field) in (None, "", []):
            errors.append((path, f"missing required frontmatter field {field!r}"))

    if fm.get("id") and not ID_RE.match(str(fm["id"])):
        errors.append((path, f"id {fm['id']!r} invalid — lowercase letters, digits, "
                       "hyphens, 3-80 chars"))
    if fm.get("kind") and fm["kind"] != FOLDER_KIND[folder]:
        errors.append((path, f"kind is {fm['kind']!r} but notes in {folder}/ must be "
                       f"{FOLDER_KIND[folder]!r}"))
    note_topics = fm.get("topics") or []
    if not isinstance(note_topics, list):
        note_topics = [note_topics]
    for t in note_topics:
        if t not in topics:
            errors.append((path, f"topic {t!r} not in knowledge/topics.yaml — known "
                           "topics: " + (", ".join(sorted(topics)) or "(none)")))
    for field in ("created", "valid_from", "review_by"):
        value = fm.get(field)
        if value and (not DATE_RE.match(str(value)) or not valid_date(value)):
            errors.append((path, f"{field} must be a real YYYY-MM-DD date, got {value!r}"))
    status = fm.get("status")
    if status and status not in STATUSES:
        errors.append((path, f"status must be one of {sorted(STATUSES)}, got {status!r}"))

    if in_archive:
        if status and status != "superseded":
            errors.append((path, "notes in archive/ must have status: superseded"))
        successor = fm.get("superseded_by")
        if not successor:
            errors.append((path, "archived note missing superseded_by"))
        elif successor not in metas:
            errors.append((path, f"superseded_by {successor!r} does not exist"))
        else:
            succ_rel, succ_fm = metas[successor]
            if succ_fm.get("supersedes") != fm.get("id"):
                warnings.append((path, f"successor {successor!r} does not point back via "
                                 f"supersedes: {fm.get('id')}"))
        body_lines = [l for l in text.splitlines()[fm.get("_end_line", 0):] if l.strip()]
        if body_lines and not body_lines[0].lstrip().startswith("> SUPERSEDED"):
            warnings.append((path, "archived note body should start with the banner "
                             "'> SUPERSEDED <date> by [[new-id]] — <reason>'"))
    else:
        if status and status != "current":
            errors.append((path, f"status is {status!r} — canonical folders hold current "
                           "notes only; superseded notes move to archive/, drafts live "
                           "in inbox/"))
        if fm.get("superseded_by"):
            errors.append((path, "a current note must not carry superseded_by — that field "
                           "marks a note as replaced and belongs only on notes in archive/. "
                           "If this note was superseded, move it there (bin/brain supersede); "
                           "if not, delete the field."))
        predecessor = fm.get("supersedes")
        if predecessor:
            if predecessor not in metas:
                errors.append((path, f"supersedes {predecessor!r} does not exist"))
            else:
                pred_rel, pred_fm = metas[predecessor]
                if pred_rel.parts[0] != "archive":
                    errors.append((path, f"supersedes {predecessor!r} but that note still "
                                   f"sits in a canonical folder — git mv it into "
                                   f"knowledge/archive/{pred_rel.parts[0]}/"))
                if pred_fm.get("status") != "superseded":
                    errors.append((path, f"supersedes {predecessor!r} but its status is "
                                   f"still {pred_fm.get('status')!r} — set status: "
                                   f"superseded and superseded_by: {fm.get('id')}"))

    sensitivity = fm.get("sensitivity")
    if folder in SENSITIVITY_REQUIRED and not sensitivity:
        errors.append((path, f"notes in {folder}/ require a sensitivity field "
                       "(normal | personal | private)"))
    if sensitivity and sensitivity not in SENSITIVITIES:
        errors.append((path, f"sensitivity must be one of {sorted(SENSITIVITIES)}"))
    if sensitivity == "private":
        errors.append((path, "sensitivity: private belongs in vault/ as an encrypted "
                       ".age file, never as plaintext (see setup/runbooks/vault.md)"))

    if folder == "decisions":
        if not DECISION_FILE_RE.match(path.name):
            errors.append((path, "decision files must be named YYYY-MM-DD-slug.md"))
        elif not valid_date(path.name[:10]):
            errors.append((path, f"decision filename date {path.name[:10]!r} is not a "
                           "real calendar date"))

    if not fm.get("aliases"):
        warnings.append((path, "no aliases — add 2-5 words future-you might search for; "
                         "this is the cheapest retrieval-precision lever"))
    m = RELATIVE_DATES.search("\n".join(text.splitlines()[fm.get("_end_line", 0):]))
    if m:
        warnings.append((path, f"relative date {m.group(0)!r} in body — use absolute "
                         "YYYY-MM-DD dates so notes stay meaningful"))
    # Archived bodies are append-only history: their links point into the
    # past on purpose and must never be "fixed", so only current notes are
    # held to a working link graph.
    if not in_archive:
        check_links(path, text, fm, ctx, hard=True)


def check_knowledge_file(rel: Path, blob: Blob, ctx: LintCtx, fm_cached=None) -> None:
    """Every placement and content rule for ONE file under knowledge/.

    Takes its bytes rather than reading them, so the same rules apply whether
    the file comes off disk (`bin/brain lint`) or out of the git index (the
    commit gate)."""
    errors, warnings = ctx.errors, ctx.warnings
    path = K / rel
    parts = rel.parts
    is_md = path.suffix.lower() == ".md"

    if blob.is_symlink:
        errors.append((path, "symlinks are not allowed in knowledge/ — git commits the "
                       "link, not the content, so the note would never be backed up"))
        return
    if path.name in (".gitkeep", ".DS_Store") or path.name.endswith(".local.md") \
            or str(rel) == "topics.yaml":
        return
    if path.name != path.name.strip() or any(ord(c) < 32 for c in path.name):
        errors.append((path, "filename has leading/trailing whitespace or control "
                       "characters — rename it"))
        return
    if len(parts) == 1:
        if str(rel) == "index.md":
            text = blob.text()
            if len(text.splitlines()) > MAX_INDEX_LINES:
                errors.append((path, f"index.md exceeds {MAX_INDEX_LINES} lines — split "
                               "it; oversized route maps stop fitting in context"))
            # The route map is the one file every search starts from — a
            # dead hub link here misroutes every future question.
            check_links(path, text, None, ctx, hard=True)
        else:
            errors.append((path, "unexpected file at knowledge/ root — notes live in "
                           "their folders (see knowledge/index.md)"))
        return

    top = parts[0]
    if top == "vault":
        if str(rel) == "vault/README.md":
            return
        if path.suffix != ".age":
            errors.append((path, "only README.md and encrypted .age files belong in "
                           "vault/ — never plaintext (see setup/runbooks/vault.md)"))
            return
        head = blob.raw[:40]
        if not (head.startswith(b"age-encryption.org/")
                or head.startswith(b"-----BEGIN AGE ENCRYPTED FILE")):
            errors.append((path, "not real age ciphertext — plaintext masquerading as "
                           ".age (encrypt it: see setup/runbooks/vault.md)"))
        return
    if top == "attachments":
        if is_md:
            errors.append((path, "notes don't belong in attachments/ — attachments hold "
                           "binaries; notes live in their folders"))
        return
    if top in ("inbox", "journal"):
        if not is_md:
            errors.append((path, f"only .md notes belong in {top}/"))
            return
        if top == "journal" and not re.match(r"^\d{4}-\d{2}-\d{2}.*\.md$", path.name,
                                             re.IGNORECASE):
            warnings.append((path, "journal files should be named YYYY-MM-DD*.md"))
        note_text = blob.text()
        fm, _err = parse_frontmatter(note_text)
        if fm and fm.get("sensitivity") == "private":
            errors.append((path, "sensitivity: private must never exist as plaintext "
                           "— encrypt into vault/ (see setup/runbooks/vault.md)"))
        # Provisional material: a bad link is worth reporting but must never
        # block a capture from committing.
        check_links(path, note_text, fm, ctx, hard=False)
        return

    in_archive = top == "archive"
    if in_archive:
        if len(parts) < 3 or parts[1] not in CANONICAL:
            errors.append((path, "archive/ must mirror canonical folders "
                           "(archive/decisions/, archive/people/, ...)"))
            return
        folder = parts[1]
    elif top in CANONICAL:
        folder = top
    else:
        errors.append((path, f"unknown folder knowledge/{top}/ — see knowledge/index.md "
                       "for where notes belong"))
        return

    max_depth = (3 if folder == "projects" else 2) + (1 if in_archive else 0)
    if len(parts) > max_depth:
        errors.append((path, f"unexpected nesting — {folder}/ holds notes at fixed "
                       "depth, no extra subfolders"))
        return

    if path.name.lower() == "index.md" and not in_archive and len(parts) == 2:
        if len(blob.text().splitlines()) > MAX_INDEX_LINES:
            errors.append((path, f"index.md exceeds {MAX_INDEX_LINES} lines — split it; "
                           "oversized route maps stop fitting in context"))
        return
    if not is_md:
        errors.append((path, f"non-markdown file in {folder}/ — canonical folders hold "
                       ".md notes only (binaries go to attachments/, secrets to vault/)"))
        return

    text = blob.text()
    if fm_cached is not None:
        fm, parse_err = fm_cached
    else:
        fm, parse_err = parse_frontmatter(text)
    if parse_err:
        errors.append((path, parse_err))
        return
    try:
        check_note(path, rel, folder, in_archive, fm, text, ctx)
    except Exception as exc:
        # A note the checker cannot process is a CONTENT defect: it must
        # block the commit (exit 1), never crash the whole gate into the
        # fail-open environment path (exit 3).
        errors.append((path, f"lint could not process this note ({exc!r}) — fix or "
                       "simplify its frontmatter"))


def check_supersede_graph(ctx: LintCtx) -> None:
    """Cross-note invariants: one successor per note, and every chain must
    terminate in a canonical folder without cycling."""
    errors, metas = ctx.errors, ctx.metas
    # A note can be superseded by exactly one successor. Two current notes both
    # claiming supersedes: X (a "forked" supersede) leaves both live, lint clean,
    # and `brain read X` silently follows only one fork — the other's knowledge
    # is served as current with no signal.
    supersedes_map: dict = {}
    for note_id, (rel, fm) in metas.items():
        target = fm.get("supersedes")
        if isinstance(target, str) and target:
            supersedes_map.setdefault(target, []).append(note_id)
    for target, claimers in supersedes_map.items():
        if len(claimers) > 1:
            first_rel = metas[claimers[0]][0]
            errors.append((K / first_rel, f"{len(claimers)} notes all claim to supersede "
                           f"{target!r} ({', '.join(sorted(claimers))}) — a note can be "
                           "superseded by exactly one successor; merge or re-chain them"))

    for note_id, (rel, fm) in metas.items():
        if rel.parts[0] != "archive":
            continue
        succ = fm.get("superseded_by")
        if not isinstance(succ, str) or succ not in metas:
            continue
        trail = [note_id]
        cur = succ
        for _ in range(50):
            if cur in trail:
                errors.append((K / rel, "supersede cycle: " + " -> ".join(trail + [cur])))
                break
            trail.append(cur)
            cur_rel, cur_fm = metas[cur]
            cur_top = cur_rel.parts[0]
            if cur_top in CANONICAL:
                break
            if cur_top == "archive":
                nxt = cur_fm.get("superseded_by")
                if not isinstance(nxt, str) or nxt not in metas:
                    break
                cur = nxt
                continue
            errors.append((K / rel, f"supersede chain ends at {cur!r} in knowledge/"
                           f"{cur_top}/ — successors must live in a canonical folder, "
                           "not inbox/journal/attachments"))
            break


class VerifyingMetas(dict):
    """The id universe for the commit gate, checked lazily against disk.

    Built from the .cache metadata so the gate does not re-read every note, but
    a cache is a claim, not a fact: a note deleted since the last index would
    still look present and a link to it would wrongly pass. Any id actually
    CONSULTED is verified once against the file it claims to live in, and
    dropped if that file is gone or no longer carries the id. Entries that came
    from the staged blobs themselves are already ground truth and skip this.
    """

    def __init__(self, base: dict, trusted: set):
        super().__init__(base)
        self._trusted = trusted
        self._checked: set = set()

    def _verify(self, key):
        if key in self._trusted or key in self._checked:
            return
        self._checked.add(key)
        if not dict.__contains__(self, key):
            return
        rel, _fm = dict.__getitem__(self, key)
        path = K / rel
        try:
            if not path.is_file():
                dict.pop(self, key, None)
                return
            fm, _err = parse_frontmatter(read_text(path))
        except OSError:
            dict.pop(self, key, None)
            return
        if not fm or fm.get("id") != key:
            dict.pop(self, key, None)

    def __contains__(self, key):
        self._verify(key)
        return dict.__contains__(self, key)

    def __getitem__(self, key):
        self._verify(key)
        return dict.__getitem__(self, key)

    def get(self, key, default=None):
        self._verify(key)
        return dict.get(self, key, default)


class StagedMetas:
    """The id universe seen through the commit, resolved one id at a time.

    Materialising every note's frontmatter to check one commit was the last
    thing making the gate scale with the size of the brain. Nothing here is
    loaded until an id is actually consulted: staged notes come from the index
    (ground truth), everything else from a single-row cache lookup that is then
    verified against the file it claims to live in — so a stale cache can
    neither invent a note nor hide one."""

    def __init__(self, index: "MetaIndex", overlay: dict, removed_rels: set, staged_rels: set,
                 recent: dict = None):
        self._index = index
        self._overlay = overlay            # id -> (rel, fm) from staged blobs
        self._removed = removed_rels       # rels this commit deletes
        self._staged = staged_rels         # rels this commit rewrites
        self._recent = recent or {}        # notes newer than the cache
        self._verified: dict = {}

    def _incumbent(self, key):
        """The note holding this id BEFORE the commit, if it still counts."""
        if key in self._verified:
            return self._verified[key]
        found = None
        candidates = []
        if key in self._recent:
            candidates.append(self._recent[key])
        candidates.extend(self._index.get_all(key))
        for rel, _fm in candidates:
            # Skip rows describing paths this commit is itself rewriting or
            # deleting — those are not an incumbent, they ARE the change.
            if rel in self._removed or rel in self._staged:
                continue
            path = K / rel
            if not path.is_file():
                continue
            try:
                live, _err = parse_frontmatter(read_text(path))
            except OSError:
                continue
            if live and live.get("id") == key:
                found = (rel, live)
                break
        self._verified[key] = found
        return found

    def incumbent(self, key):
        return self._incumbent(key)

    def who_supersedes(self, target_id) -> list:
        """Every note claiming `supersedes: target_id`, from all three sources —
        the cache, notes newer than it, and this commit's own blobs."""
        found = set(self._index.who_supersedes(target_id))
        for source in (self._recent, self._overlay):
            for nid, (_rel, fm) in source.items():
                if fm.get("supersedes") == target_id:
                    found.add(nid)
        # An id only counts if it still resolves and still makes the claim.
        return [nid for nid in found
                if (self.get(nid) or (None, {}))[1].get("supersedes") == target_id]

    def __contains__(self, key):
        return key in self._overlay or self._incumbent(key) is not None

    def __getitem__(self, key):
        if key in self._overlay:
            return self._overlay[key]
        found = self._incumbent(key)
        if found is None:
            raise KeyError(key)
        return found

    def get(self, key, default=None):
        try:
            return self[key]
        except KeyError:
            return default


def check_supersede_graph_staged(ctx, staged_ids, index) -> None:
    """Graph invariants, restricted to what this commit can actually break.

    A fork or a broken chain needs a staged note to participate — anything else
    is pre-existing and is not this commit's to refuse."""
    metas = ctx.metas
    for note_id in staged_ids:
        entry = metas.get(note_id)
        if entry is None:
            continue
        rel, fm = entry
        target = fm.get("supersedes")
        if isinstance(target, str) and target:
            lookup = metas if hasattr(metas, "who_supersedes") else index
            claimers = {c for c in lookup.who_supersedes(target) if c != note_id}
            if claimers:
                ctx.errors.append((K / rel, f"{len(claimers) + 1} notes all claim to supersede "
                                   f"{target!r} ({', '.join(sorted(claimers | {note_id}))}) — a "
                                   "note can be superseded by exactly one successor; merge or "
                                   "re-chain them"))
        if rel.parts[0] != "archive":
            continue
        succ = fm.get("superseded_by")
        if not isinstance(succ, str) or succ not in metas:
            continue
        trail, cur = [note_id], succ
        for _ in range(50):
            if cur in trail:
                ctx.errors.append((K / rel, "supersede cycle: " + " -> ".join(trail + [cur])))
                break
            trail.append(cur)
            cur_entry = metas.get(cur)
            if cur_entry is None:
                break
            cur_rel, cur_fm = cur_entry
            cur_top = cur_rel.parts[0]
            if cur_top in CANONICAL:
                break
            if cur_top == "archive":
                nxt = cur_fm.get("superseded_by")
                if not isinstance(nxt, str) or nxt not in metas:
                    break
                cur = nxt
                continue
            ctx.errors.append((K / rel, f"supersede chain ends at {cur!r} in knowledge/"
                               f"{cur_top}/ — successors must live in a canonical folder, "
                               "not inbox/journal/attachments"))
            break


def notes_modified_since(when: float) -> list:
    """Notes touched after `when` — normally a handful.

    The cache knows every note that existed when it was built; this covers
    everything since. Together they are a COMPLETE universe, which matters
    because a cache alone can never prove a note's absence — and "no other note
    holds this id" is exactly what duplicate detection has to establish."""
    import os
    out, stack = [], [str(K)]
    while stack:
        try:
            entries = os.scandir(stack.pop())
        except OSError:
            continue
        with entries:
            for entry in entries:
                try:
                    if entry.is_dir(follow_symlinks=False):
                        if entry.name not in ("vault", "attachments"):
                            stack.append(entry.path)
                    elif entry.name.lower().endswith(".md") and entry.stat().st_mtime > when:
                        out.append(Path(entry.path))
                except OSError:
                    continue
    return out


def recent_note_metas() -> dict:
    """id -> (rel, fm) for notes newer than the cache, so the gate sees them."""
    try:
        built = INDEX_DB.stat().st_mtime if INDEX_DB.exists() else 0.0
    except OSError:
        built = 0.0
    recent = {}
    for path in notes_modified_since(built):
        try:
            fm, _err = parse_frontmatter(read_text(path))
        except OSError:
            continue
        if fm and isinstance(fm.get("id"), str) and fm["id"]:
            recent[fm["id"]] = (path.relative_to(K), fm)
    return recent


def staged_overlay(changes):
    """(id -> (rel, fm) for staged notes, rels deleted, rels rewritten)."""
    overlay, removed_rels, staged_rels = {}, set(), set()
    for status, rel_str in changes:
        parts = Path(rel_str).parts
        if not parts or parts[0] != "knowledge" or len(parts) < 2:
            continue
        rel = Path(*parts[1:])
        if status == "D":
            removed_rels.add(rel)
            continue
        staged_rels.add(rel)
        blob = staged_blob(rel_str)
        if blob is None:
            continue
        fm, _err = parse_frontmatter(blob[0].decode("utf-8-sig", errors="replace"))
        if fm and isinstance(fm.get("id"), str) and fm["id"]:
            overlay[fm["id"]] = (rel, fm)
    return overlay, removed_rels, staged_rels


def staged_changes():
    """[(status, rel)] for what this commit changes, or None if git won't say."""
    raw = git("diff", "--cached", "--name-status", "-z")
    if not raw:
        return []
    fields = [f for f in raw.split("\0") if f]
    out, i = [], 0
    while i < len(fields):
        status = fields[i]
        if status[:1] in ("R", "C"):        # rename/copy: source then destination
            if i + 2 >= len(fields):
                return None
            out.append(("A", fields[i + 2]))
            out.append(("D", fields[i + 1]))
            i += 3
            continue
        if i + 1 >= len(fields):
            return None
        out.append((status[:1], fields[i + 1]))
        i += 2
    return out


def staged_blob(rel: str):
    """(bytes, is_symlink) for a path as it sits in the index, or None."""
    mode = subprocess.run(["git", "ls-files", "--stage", "--", rel],
                          cwd=ROOT, capture_output=True, text=True)
    is_symlink = mode.stdout.startswith("120000")
    content = subprocess.run(["git", "cat-file", "blob", f":{rel}"],
                             cwd=ROOT, capture_output=True)
    if content.returncode != 0:
        return None
    return content.stdout, is_symlink


def removed_note_ids(changes) -> set:
    """Ids this commit takes out of circulation — a deleted note, or one whose
    id was changed. Both orphan every [[link]] pointing at the old id."""
    removed = set()
    for status, rel_str in changes:
        parts = Path(rel_str).parts
        if not parts or parts[0] != "knowledge" or not rel_str.lower().endswith(".md"):
            continue
        head = subprocess.run(["git", "cat-file", "blob", f"HEAD:{rel_str}"],
                              cwd=ROOT, capture_output=True)
        if head.returncode != 0:
            continue                       # newly added; nothing to orphan
        was, _err = parse_frontmatter(head.stdout.decode("utf-8-sig", errors="replace"))
        old_id = (was or {}).get("id")
        if not isinstance(old_id, str) or not old_id:
            continue
        if status == "D":
            removed.add(old_id)
            continue
        blob = staged_blob(rel_str)
        if blob is None:
            continue
        now, _err = parse_frontmatter(blob[0].decode("utf-8-sig", errors="replace"))
        if (now or {}).get("id") != old_id:
            removed.add(old_id)
    return removed


def flag_orphaned_inbound_links(removed: set, changes, ctx: LintCtx) -> None:
    """Report notes left pointing at an id this commit removes.

    The incremental gate only inspects what changed, so on its own it would let
    a deletion silently break every note linking to it — the exact rot link
    validation exists to catch. Deletions are rare, so this walks the corpus
    only when one actually happens, and is therefore exact rather than
    cache-dependent."""
    if not removed:
        return
    gone = {Path(*Path(r).parts[1:]) for s, r in changes
            if s == "D" and Path(r).parts[:1] == ("knowledge",)}
    for path in K.rglob("*.md"):
        rel = path.relative_to(K)
        if rel in gone or rel.parts[0] in ("archive", "vault", "attachments"):
            continue                       # archive is append-only history
        try:
            text = read_text(path)
        except OSError:
            continue
        fm, _err = parse_frontmatter(text)
        start = (fm or {}).get("_end_line", 0)
        body = "\n".join(text.splitlines()[start:])
        provisional = rel.parts[0] in ("inbox", "journal")
        for target in extract_links(body):
            if target in removed and target != (fm or {}).get("supersedes"):
                bucket = ctx.warnings if provisional else ctx.errors
                bucket.append((path, f"dangling wikilink [[{target}]] — no note has that id "
                               "(typo, or the note was deleted rather than superseded)"))


def run_staged_checks(changes, metas, topics, trusted, existing_ids=None,
                      graph_index=None) -> LintCtx:
    """Apply every rule to the staged snapshot only.

    `existing_ids` maps id -> rel for notes this commit does NOT touch. It must
    be captured BEFORE the staged versions are overlaid: the universe is keyed
    by id, so a new note carrying an id that is already taken would otherwise
    overwrite the incumbent and the collision would vanish instead of raising.
    """
    existing_ids = existing_ids or {}
    ctx = LintCtx(topics, metas)
    if not topics:
        ctx.warnings.append((K / "topics.yaml", "topic vocabulary is empty or missing"))
    ids_seen: dict = {}
    for status, rel_str in changes:
        if status == "D":
            continue                       # nothing to inspect in a deletion
        blob = staged_blob(rel_str)
        if blob is None:
            continue
        raw, is_symlink = blob
        path = ROOT / rel_str
        if len(raw) > MAX_FILE_BYTES:
            ctx.errors.append((path, f"file is {len(raw):,} bytes — the in-repo cap is 1MB; "
                               "large binaries go to the external store "
                               "(knowledge/attachments/ policy)"))
        in_vault = path.suffix == ".age" and "vault" in path.parts
        if path.suffix == ".age" and not in_vault:
            ctx.errors.append((path, "encrypted .age files live only in knowledge/vault/"))
        if not in_vault and len(raw) <= 2_000_000 and not is_symlink:
            scan_secrets(path, ctx.errors, raw=raw)
            if path.suffix.lower() == ".md":
                scan_conflicts(path, ctx.errors,
                               text=raw.decode("utf-8-sig", errors="replace"))
        parts = Path(rel_str).parts
        if parts and parts[0] == "knowledge" and len(parts) > 1:
            rel = Path(*parts[1:])
            check_knowledge_file(rel, Blob(raw, is_symlink=is_symlink), ctx)
            fm, _err = parse_frontmatter(raw.decode("utf-8-sig", errors="replace"))
            if fm and isinstance(fm.get("id"), str) and fm["id"]:
                ids_seen.setdefault(fm["id"], []).append(rel)

    # Duplicate ids: only ones this commit actually participates in. A
    # pre-existing collision elsewhere is not this commit's to block.
    for note_id, rels in ids_seen.items():
        clash = [str(r) for r in rels[1:]]
        if hasattr(metas, "incumbent"):
            held = metas.incumbent(note_id)
            incumbent = held[0] if held else None
        else:
            incumbent = (existing_ids or {}).get(note_id)
        if incumbent is not None and incumbent not in rels:
            clash.append(str(incumbent))
        if clash:
            ctx.errors.append((K / rels[0], f"duplicate id {note_id!r} also used by: "
                               + ", ".join(clash)))
    if graph_index is not None:
        check_supersede_graph_staged(ctx, list(ids_seen), graph_index)
    else:
        check_supersede_graph(ctx)
    flag_orphaned_inbound_links(removed_note_ids(changes), changes, ctx)
    return ctx


def lint_staged():
    """The commit gate, costing O(what changed) instead of O(whole brain).

    Returns an exit code, or None to mean "I could not do this safely — use the
    slow, certain path". Every per-file rule runs against the exact bytes in the
    index. Cross-note rules need the whole id universe, which comes from the
    derived cache rather than from re-reading every note; because that universe
    is the one approximate input, ANY error triggers a second pass against a
    freshly scanned universe before the commit is refused. A wrong block is
    therefore impossible, and the expensive scan only happens when something is
    already wrong.
    """
    changes = staged_changes()
    if changes is None:
        return None
    if not changes:
        print("brain lint: nothing staged")
        return 0
    topics = load_topics()

    def universe(authoritative: bool):
        trusted = set()
        if authoritative:
            base = all_metas_scan()
        else:
            base = all_metas()             # cache-backed, may lag reality
        base = dict(base)
        for status, rel_str in changes:    # overlay what this commit does
            parts = Path(rel_str).parts
            if not parts or parts[0] != "knowledge" or len(parts) < 2:
                continue
            rel = Path(*parts[1:])
            for nid, (r, _fm) in list(base.items()):
                if r == rel:
                    del base[nid]
        # Snapshot the untouched notes' ids BEFORE overlaying, so a staged note
        # claiming a taken id collides instead of silently replacing it.
        existing_ids = {nid: r for nid, (r, _fm) in base.items()}
        for status, rel_str in changes:
            parts = Path(rel_str).parts
            if not parts or parts[0] != "knowledge" or len(parts) < 2 or status == "D":
                continue
            rel = Path(*parts[1:])
            blob = staged_blob(rel_str)
            if blob is None:
                continue
            fm, _err = parse_frontmatter(blob[0].decode("utf-8-sig", errors="replace"))
            if fm and isinstance(fm.get("id"), str) and fm["id"]:
                base[fm["id"]] = (rel, fm)
                trusted.add(fm["id"])
        return base, trusted, existing_ids

    try:
        # Fast path: nothing but the staged blobs is read up front. Ids are
        # resolved one at a time, and only if some check actually asks.
        # require_fresh=False on purpose: the index is stale at almost every
        # commit (a capture just wrote a note), and refusing it would drop
        # straight back to an O(N) scan. Staleness is safe here because every id
        # consulted is verified against the file it claims to live in, and
        # anything newer than the cache is picked up by recent_note_metas().
        index = MetaIndex(require_fresh=False)
        try:
            overlay, removed_rels, staged_rels = staged_overlay(changes)
            lazy = StagedMetas(index, overlay, removed_rels, staged_rels,
                               recent=recent_note_metas())
            ctx = run_staged_checks(changes, lazy, topics, set(overlay),
                                    graph_index=index)
        finally:
            index.close()
        if ctx.errors:
            # Never refuse a commit on the word of a cache. Re-check against a
            # universe read from the notes themselves; if the errors were an
            # artefact of stale metadata they disappear here.
            base, trusted, existing = universe(authoritative=True)
            ctx = run_staged_checks(changes, dict(base), topics, trusted,
                                    existing_ids=existing)
    except Exception:
        return None                        # anything unexpected: use the slow path

    for path, msg in ctx.errors:
        print(f"ERROR  {relpath_for_display(path)}: {msg}")
    for path, msg in ctx.warnings:
        print(f"warn   {relpath_for_display(path)}: {msg}")
    print(f"\nbrain lint: {len(ctx.errors)} error(s), {len(ctx.warnings)} warning(s) "
          f"[staged: {len(changes)} path(s)]")
    return 1 if ctx.errors else 0


def relpath_for_display(path: Path) -> str:
    try:
        return str(path.relative_to(ROOT))
    except ValueError:
        return str(path)


def lint(staged_only: bool = False) -> int:
    if staged_only:
        code = lint_staged()
        if code is not None:
            return code
        # Fell back: something made the incremental gate untrustworthy, so lint
        # the exact snapshot being committed the slow, certain way.
        import os
        import tempfile
        staged = [p for p in git("diff", "--cached", "--name-only", "-z").split("\0") if p]
        if not staged:
            print("brain lint: nothing staged")
            return 0
        with tempfile.TemporaryDirectory() as tmp:
            subprocess.run(["git", "checkout-index", "--all", f"--prefix={tmp}/"],
                           cwd=ROOT, check=True)
            env = dict(os.environ, BRAIN_LINT_SCAN_ONLY="\n".join(staged))
            child = subprocess.run(
                [sys.executable, str(Path(__file__).resolve()), "lint", "--root", tmp], env=env)
            return child.returncode

    errors: list = []
    warnings: list = []
    topics = load_topics()
    if not topics:
        warnings.append((K / "topics.yaml", "topic vocabulary is empty or missing"))

    notes = collect_notes()
    ids: dict = {}
    metas: dict = {}
    for rel, (fm, _err) in notes.items():
        # Only string ids can be keys; malformed ids (lists etc.) are reported
        # per-note by check_note and must not crash this collection pass.
        if fm and isinstance(fm.get("id"), str) and fm["id"]:
            metas.setdefault(fm["id"], (rel, fm))
            ids.setdefault(fm["id"], []).append(rel)
    for note_id, paths in ids.items():
        if len(paths) > 1:
            errors.append((K / paths[0], f"duplicate id {note_id!r} also used by: "
                           + ", ".join(str(p) for p in paths[1:])))

    # Repo-wide sweeps: secrets in ANY text file, size cap on ANY file —
    # regardless of extension, folder, or filename. Only genuine vault
    # ciphertext is exempt from the secret scan; a plaintext file merely
    # NAMED .age gets scanned like everything else.
    # __pycache__ holds gitignored, derived bytecode that is never committed —
    # and Python constant-folds string expressions into it, so scanning it
    # reports "secrets" that exist in no source file and cannot be fixed.
    skip_parts = {".git", ".cache", "graphify-out", "node_modules", "__pycache__"}
    # Set by the --staged gate: restrict the byte-level sweep (secrets, size,
    # conflict markers) to the paths actually being committed. Unset for a full
    # `bin/brain lint`, which always sweeps the entire repo.
    import os as _os
    scan_only = _os.environ.get("BRAIN_LINT_SCAN_ONLY")
    scan_only = {p for p in scan_only.split("\n") if p} if scan_only else None
    for path in ROOT.rglob("*"):
        if set(path.parts) & skip_parts or path.name == ".DS_Store" \
                or path.name.endswith(".local.md"):
            continue
        if scan_only is not None:
            try:
                if str(path.relative_to(ROOT)) not in scan_only:
                    continue
            except ValueError:
                continue
        if path.is_symlink() or not path.is_file():
            continue
        size = path.stat().st_size
        if size > MAX_FILE_BYTES:
            errors.append((path, f"file is {size:,} bytes — the in-repo cap is 1MB; large "
                           "binaries go to the external store (knowledge/attachments/ policy)"))
        in_vault = path.suffix == ".age" and "vault" in path.parts
        if path.suffix == ".age" and not in_vault:
            errors.append((path, "encrypted .age files live only in knowledge/vault/"))
        if in_vault or size > 2_000_000:
            continue
        # Read the bytes ONCE and share them with both scanners; this loop runs
        # over every file in the repo, so a second read here is a second full
        # pass over the corpus.
        try:
            raw = path.read_bytes()
        except OSError as exc:
            errors.append((path, f"unreadable file: {exc}"))
            continue
        scan_secrets(path, errors, raw=raw)
        if path.suffix.lower() == ".md":
            scan_conflicts(path, errors, text=raw.decode("utf-8-sig", errors="replace"))

    ctx = LintCtx(topics, metas)
    ctx.errors = errors
    ctx.warnings = warnings
    for path in sorted(K.rglob("*")):
        if not path.is_symlink() and not path.is_file():
            continue
        rel = path.relative_to(K)
        try:
            blob = Blob.from_disk(path)
        except OSError as exc:
            errors.append((path, f"unreadable file: {exc}"))
            continue
        check_knowledge_file(rel, blob, ctx, fm_cached=notes.get(rel))

    check_supersede_graph(ctx)

    for path, msg in errors:
        print(f"ERROR  {path.relative_to(ROOT)}: {msg}")
    for path, msg in warnings:
        print(f"warn   {path.relative_to(ROOT)}: {msg}")
    print(f"\nbrain lint: {len(errors)} error(s), {len(warnings)} warning(s)")
    return 1 if errors else 0


def render_template(kind: str, values: dict) -> str:
    template_path = ROOT / "setup" / "templates" / f"{kind}.md"
    text = template_path.read_text(encoding="utf-8")
    for key, value in values.items():
        text = text.replace("{{" + key + "}}", value)
    return text


def unique_id(candidate: str) -> str:
    """First free id in the <candidate>, <candidate>-2, <candidate>-3 … series.

    Answered with point lookups: collecting every id in the brain to test one
    string put note CREATION on an O(total notes) path too."""
    metas = MetaIndex()
    try:
        if not metas.exists(candidate):
            return candidate
        n = 2
        while metas.exists(f"{candidate}-{n}"):
            n += 1
        return f"{candidate}-{n}"
    finally:
        metas.close()


def cmd_init(argv: list) -> int:
    """Wire a fresh clone into Claude — the five steps documented in SETUP.md
    Part 2. Every step is idempotent: re-running init is always safe, and is
    the documented fix when a machine's wiring drifts.

    The two files written here (.mcp.json, SKILL.md) hold THIS clone's absolute
    paths, which is exactly why they are gitignored and regenerated per machine
    rather than committed.
    """
    import json as _json
    import shutil

    mcp_server = ROOT / "bin" / "brain-mcp"
    skill_dir = ROOT / "setup" / "skills" / "brain"
    template = skill_dir / "SKILL.md.template"
    skill = skill_dir / "SKILL.md"
    failures = []

    # 1. git hooks — the commit gate. Report what git actually did: claiming
    # the gate is installed when it is not is worse than saying nothing.
    hooks = subprocess.run(["git", "config", "core.hooksPath", ".githooks"],
                           cwd=ROOT, capture_output=True, text=True)
    if hooks.returncode == 0:
        print("  [1/5] git hooks       core.hooksPath = .githooks")
    else:
        failures.append(f"could not set core.hooksPath ({hooks.stderr.strip() or 'git failed'})"
                        " — is this a git clone? the commit gate is NOT active")
        print("  [1/5] FAILED          could not set core.hooksPath — not a git repo?")

    # 2. .mcp.json — brain tools for Claude Code sessions started INSIDE the repo.
    # MERGE rather than overwrite: this file is gitignored now, so clobbering
    # another server's entry here would destroy it with no way to get it back.
    mcp_file = ROOT / ".mcp.json"
    try:
        config = {}
        if mcp_file.exists():
            try:
                config = _json.loads(mcp_file.read_text(encoding="utf-8"))
            except (ValueError, OSError):
                config = {}
            if not isinstance(config, dict):
                config = {}
        servers = config.get("mcpServers")
        if not isinstance(servers, dict):
            servers = {}
        others = sorted(k for k in servers if k != "brain")
        servers["brain"] = {"command": str(mcp_server), "args": []}
        config["mcpServers"] = servers
        mcp_file.write_text(_json.dumps(config, indent=2) + "\n", encoding="utf-8")
        kept = f" (kept: {', '.join(others)})" if others else ""
        print("  [2/5] .mcp.json       -> " + str(mcp_server) + kept)
    except OSError as exc:
        failures.append(f"could not write .mcp.json: {exc}")
        print(f"  [2/5] FAILED          {exc}")

    # 3. render the /brain skill for this clone's path.
    if not template.exists():
        failures.append(f"missing {template.relative_to(ROOT)} — cannot render the skill")
        print(f"  [3/5] SKIPPED         missing {template.relative_to(ROOT)}")
    else:
        try:
            rendered = template.read_text(encoding="utf-8").replace("{{REPO}}", str(ROOT))
            skill.write_text(rendered, encoding="utf-8")
            print("  [3/5] skill rendered  " + str(skill.relative_to(ROOT)))
        except OSError as exc:
            failures.append(f"could not render {skill.relative_to(ROOT)}: {exc}")
            print(f"  [3/5] FAILED          {exc}")

    # 4. symlink the skill into ~/.claude/skills/ so /brain works in any session.
    # Only once there is a rendered SKILL.md to point at — a link into a
    # directory Claude finds no skill in is worse than no link at all.
    link = Path.home() / ".claude" / "skills" / "brain"
    if not skill.is_file():
        failures.append(f"no rendered {skill.name} to link — fix step 3, then re-run init")
        print(f"  [4/5] SKIPPED         nothing to link (no {skill.name})")
    else:
        try:
            link.parent.mkdir(parents=True, exist_ok=True)
            if link.is_symlink():
                if link.resolve() == skill_dir.resolve():
                    print("  [4/5] skill linked    already correct")
                else:
                    link.unlink()
                    link.symlink_to(skill_dir)
                    print("  [4/5] skill relinked  " + str(link))
            elif link.exists():
                failures.append(f"{link} exists and is not a symlink — move it aside, "
                                "re-run init")
                print(f"  [4/5] SKIPPED         {link} exists and is not a symlink")
            else:
                link.symlink_to(skill_dir)
                print("  [4/5] skill linked    " + str(link))
        except OSError as exc:
            failures.append(f"could not link {link}: {exc}")
            print(f"  [4/5] FAILED          {exc}")

    # 5. register the MCP server at user scope — brain tools in ANY directory.
    # `claude mcp add` REFUSES when an entry exists and never updates it, and it
    # says "already exists" whether or not the registered path is this clone. So
    # check where the entry actually points: a clone that moved is exactly when
    # someone re-runs init, and reporting success there leaves every session
    # outside the repo wired to a path that no longer exists.
    #
    # Ask `mcp get`, never `mcp list`: step 2 wrote a PROJECT-scoped .mcp.json
    # moments ago, and `list` — run here with cwd=ROOT — reports that entry
    # indistinguishably from a user-scope one. Trusting `list` means a fresh
    # machine sees brain "already registered", skips the add, and ends up with
    # brain tools INSIDE this repo and nowhere else, which is the one thing this
    # step exists to prevent. `mcp get` names the scope, so only a genuine
    # user-scope entry counts as registered.
    manual = f'claude mcp add --scope user brain "{mcp_server}"'
    repair = f'claude mcp remove brain -s user && {manual}'
    if not shutil.which("claude"):
        print("  [5/5] deferred        'claude' CLI not found — run later:")
        print(f"                        {manual}")
    else:
        try:
            got = subprocess.run(["claude", "mcp", "get", "brain"], cwd=ROOT,
                                 capture_output=True, text=True, timeout=60)
            scope = current = None
            for row in got.stdout.splitlines():
                field = row.strip()
                if field.startswith("Scope:"):
                    scope = field.split(":", 1)[1].strip()
                elif field.startswith("Command:"):
                    current = field.split(":", 1)[1].strip()
            # A project- or local-scoped entry is NOT what this step promises,
            # so it counts as absent and the add below still runs.
            registered = scope is not None and scope.lower().startswith("user")
            if registered and current is None:
                # Present at user scope but not as a stdio command we can check
                # against this clone. Unverifiable is not the same as fine.
                failures.append(f"MCP server 'brain' exists at user scope but its command "
                                f"could not be read, so it cannot be confirmed to point at "
                                f"this clone. Repair with: {repair}")
                print("  [5/5] FAILED          unverifiable registration — run:")
                print(f"                        {repair}")
            elif registered and str(mcp_server) not in current:
                failures.append(f"MCP server 'brain' is registered to a DIFFERENT path "
                                f"({current}) — sessions outside this "
                                f"repo will use that one. Repair with: {repair}")
                print("  [5/5] FAILED          registered elsewhere — run:")
                print(f"                        {repair}")
            elif registered:
                print("  [5/5] mcp registered  already present")
            else:
                reg = subprocess.run(
                    ["claude", "mcp", "add", "--scope", "user", "brain", str(mcp_server)],
                    cwd=ROOT, capture_output=True, text=True, timeout=60)
                detail = (reg.stderr.strip() or reg.stdout.strip()).splitlines()
                detail = detail[-1] if detail else ""
                if reg.returncode == 0:
                    print("  [5/5] mcp registered  user scope")
                else:
                    failures.append(f"claude mcp add failed: {detail or 'non-zero exit'}")
                    print(f"  [5/5] FAILED          {detail or 'non-zero exit'} — run: {manual}")
        except (OSError, subprocess.SubprocessError) as exc:
            failures.append(f"claude mcp registration failed: {exc!r}")
            print(f"  [5/5] FAILED          {exc!r} — run: {manual}")

    if failures:
        print("\nbrain init finished WITH PROBLEMS:")
        for f in failures:
            print(f"  - {f}")
        return 1
    print("\nbrain init complete. Restart Claude sessions — MCP servers and skills "
          "load at session start.")
    print("Verify:  claude mcp list   and   bin/brain doctor")
    return 0


def cmd_new(argv: list) -> int:
    if not argv:
        print("usage: brain new <decision|reference|topic|person|project|note> \"<title>\" "
              "[--topics a,b] [--sensitivity normal|personal]")
        return 2
    kind = argv[0]
    title = argv[1] if len(argv) > 1 else None
    if kind == "journal":
        today = date.today().isoformat()
        path = K / "journal" / today[:4] / f"{today}.md"
        path.parent.mkdir(parents=True, exist_ok=True)
        if not path.exists():
            path.write_text(f"# {today}\n\n", encoding="utf-8")
        print(path)
        return 0
    if kind not in FOLDER_KIND.values():
        print(f"unknown kind {kind!r} — one of: {', '.join(sorted(set(FOLDER_KIND.values())))}, journal")
        return 2
    if not title:
        print("a title is required")
        return 2

    topics_arg = ""
    sensitivity = "personal" if kind in ("person",) else "normal"
    for i, arg in enumerate(argv):
        if arg == "--topics" and i + 1 < len(argv):
            topics_arg = argv[i + 1]
        if arg == "--sensitivity" and i + 1 < len(argv):
            sensitivity = argv[i + 1]

    vocabulary = load_topics()
    chosen = [t.strip() for t in topics_arg.split(",") if t.strip()]
    if not chosen:
        print("--topics is required (correct-by-construction: lint rejects notes without "
              "topics). Known topics: " + (", ".join(sorted(vocabulary)) or "(none)"))
        return 2
    for t in chosen:
        if t not in vocabulary:
            print(f"topic {t!r} is not in knowledge/topics.yaml — add it there first. "
                  "Known topics: " + (", ".join(sorted(vocabulary)) or "(none)"))
            return 1

    today = date.today().isoformat()
    slug = slugify(title)
    folder = {v: k for k, v in FOLDER_KIND.items()}[kind]
    if kind == "decision":
        note_id = unique_id(f"{today}-{slug}")
        path = K / folder / f"{note_id}.md"
    elif kind == "project":
        note_id = unique_id(f"project-{slug}")
        path = K / folder / note_id.removeprefix("project-") / "overview.md"
    else:
        note_id = unique_id(slug)
        path = K / folder / f"{note_id}.md"
    if path.exists():
        print(f"a note with this slug already exists: {path} — edit it, or choose a "
              "different title")
        return 1
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(
        render_template(kind, {
            "ID": note_id,
            "TITLE": title,
            "DATE": today,
            "TOPICS": ", ".join(chosen),
            "SENSITIVITY": sensitivity,
        }),
        encoding="utf-8",
    )
    print(path)
    print("now: fill the body, add 2-5 aliases, then run 'bin/brain lint'")
    return 0


def cmd_capture(argv: list) -> int:
    do_commit = "--commit" in argv
    text = " ".join(a for a in argv if a != "--commit").strip()
    if not text:
        print("usage: brain capture \"<text>\" [--commit]")
        return 2
    today = date.today().isoformat()
    stamp = time.strftime("%H%M%S")
    slug = slugify(text)[:40]
    path = K / "inbox" / f"{today}-{stamp}-{slug}.md"
    n = 2
    while path.exists():
        path = K / "inbox" / f"{today}-{stamp}-{slug}-{n}.md"
        n += 1
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(f"---\ncreated: {today}\nstatus: draft\n---\n\n{text}\n", encoding="utf-8")
    print(path)
    if do_commit:
        # --commit was ASKED for, so failing to commit is a failure: the note
        # exists only on this machine, unvetted and unbacked. Returning 0 here
        # made the MCP layer report isError:false and every caller believe the
        # note was safely in git.
        branch = git("rev-parse", "--abbrev-ref", "HEAD")
        if branch.startswith("consolidate/"):
            # A capture committed onto the consolidation branch gets carried off
            # to a review branch and vanishes from main's working tree. Write to
            # disk (never lost), skip the commit, tell the truth.
            print(f"SAVED BUT NOT COMMITTED: currently on branch {branch!r} "
                  "(a consolidation pass is running). The note is on disk at the path "
                  "above and is NOT lost — commit it from main once consolidation lands.")
            return 1
        # Commit ONLY this note's path (git commit -- <path>), under a lock:
        #  - the pathspec keeps unrelated staged work-in-progress out of the
        #    capture commit, and
        #  - the lock removes the concurrent-capture index race.
        with repo_lock():
            add = subprocess.run(["git", "add", str(path)], cwd=ROOT,
                                 capture_output=True, text=True)
            commit = subprocess.run(
                ["git", "commit", "-m", f"capture: {slug}", "--", str(path)],
                cwd=ROOT, capture_output=True, text=True,
            )
        if add.returncode != 0 or commit.returncode != 0:
            detail = (commit.stderr.strip() or commit.stdout.strip()
                      or add.stderr.strip() or "git failed")
            print(f"SAVED BUT NOT COMMITTED: {detail}")
            print("The note is on disk at the path above and is NOT lost — do not "
                  "capture it again. Commit it once the problem is fixed.")
            return 1
        print("captured and committed — push runs in background "
              "(bin/brain doctor verifies backup)")
    return 0


INDEX_DB = ROOT / ".cache" / "index.db"
FOLDER_WEIGHTS = {"decisions": 1.2, "reference": 1.2, "topics": 1.0, "projects": 1.0,
                  "people": 1.0, "life": 1.0, "journal": 0.6, "inbox": 0.6}


WIKILINK_RE = re.compile(r"\[\[\s*([^\]\[|#\n]+?)\s*(?:[|#][^\]\n]*)?\]\]")


def extract_links(body: str) -> list:
    """Wikilink targets in a note body, in order, de-duplicated.

    Accepts [[note-id]], [[note-id|display text]] and [[note-id#section]] —
    the target is everything before the first | or #."""
    seen, out = set(), []
    for m in WIKILINK_RE.finditer(body or ""):
        target = m.group(1).strip()
        if target and target not in seen:
            seen.add(target)
            out.append(target)
    return out


def indexable_paths():
    """Every note the search index should contain — canonical + journal +
    inbox, never archive/vault/attachments. Single definition so the index and
    its freshness check can never disagree about what belongs in it."""
    for path in sorted(K.rglob("*.md")):
        rel = path.relative_to(K)
        if rel.parts[0] in ("archive", "vault", "attachments") or path.name in EXEMPT_NAMES:
            continue
        yield path


def all_note_paths():
    """Every note with frontmatter, INCLUDING archive/ — the id->path universe.

    Wider than indexable_paths() on purpose: search must not return superseded
    notes, but id resolution must still find them, because that is exactly how
    `brain read <old-id>` follows a supersede chain to the current version."""
    for path in sorted(K.rglob("*.md")):
        rel = path.relative_to(K)
        if rel.parts[0] in ("vault", "attachments"):
            continue
        yield path


def note_records():
    """Indexable records for searchable notes (canonical + journal + inbox; never archive/vault)."""
    for path in indexable_paths():
        top = path.relative_to(K).parts[0]
        text = read_text(path)
        fm, _err = parse_frontmatter(text)
        body = text
        if fm:
            body = "\n".join(text.splitlines()[fm.get("_end_line", 0):])
        aliases = (fm or {}).get("aliases") or []
        topics_list = (fm or {}).get("topics") or []
        yield {
            "id": (fm or {}).get("id") or f"{top}-{path.stem}",
            "path": str(path.relative_to(ROOT)),
            "title": str((fm or {}).get("title") or path.stem),
            "folder": top,
            "kind": str((fm or {}).get("kind") or top),
            "created": str((fm or {}).get("created") or ""),
            "aliases": ", ".join(aliases if isinstance(aliases, list) else [str(aliases)]),
            "topics": ", ".join(topics_list if isinstance(topics_list, list) else [str(topics_list)]),
            "body": body,
            "links": extract_links(body),
        }


def cmd_index(quiet: bool = False, skip_if_fresh: bool = False) -> int:
    """Rebuild the FTS index atomically, one builder at a time.

    Every Claude session runs its own MCP server, and each one rebuilds on its
    first stale search — so N of them start at the same instant. They used to
    share ONE temp path and destroy each other's half-built database ("table
    fts already exists", "disk I/O error"). Now: an advisory lock elects a
    single builder, the loser finds the index already fresh, and the build goes
    to a private temp file swapped in by atomic rename.
    """
    import os
    import sqlite3
    try:
        import fcntl
    except ImportError:  # non-POSIX: unique temp + atomic rename still hold
        fcntl = None

    INDEX_DB.parent.mkdir(exist_ok=True)
    lock_file = open(INDEX_DB.with_name("index.lock"), "w")
    try:
        if fcntl is not None:
            fcntl.flock(lock_file, fcntl.LOCK_EX)
        if skip_if_fresh and not index_stale():
            return 0                      # another process just built it
        tmp = INDEX_DB.with_name(f"index.db.{os.getpid()}.tmp")
        try:
            db = sqlite3.connect(tmp)
            db.execute(
                "CREATE VIRTUAL TABLE fts USING fts5(title, aliases, topics, body, "
                "id UNINDEXED, path UNINDEXED, folder UNINDEXED, kind UNINDEXED, "
                "created UNINDEXED, tokenize='porter unicode61 remove_diacritics 2')"
            )
            # The [[wikilink]] graph, derived in this same pass — note_records()
            # already reads every body, so backlinks cost no extra scan. Like
            # the FTS table this is disposable: rebuilt from the notes, never
            # authoritative.
            db.execute("CREATE TABLE links (src TEXT NOT NULL, dst TEXT NOT NULL)")
            # id -> path/frontmatter for EVERY note including archive/. Without
            # it, resolving one id meant re-reading and re-parsing the whole
            # corpus (collect_notes), which put `brain read` — the primary
            # retrieval verb — on an O(total notes) path. The whole frontmatter
            # is stored verbatim as JSON so consumers get byte-identical
            # semantics to a live parse, not a lossy projection of it.
            db.execute("CREATE TABLE notes_meta (id TEXT, rel TEXT, status TEXT, "
                       "superseded_by TEXT, supersedes TEXT, review_by TEXT, fm_json TEXT)")
            db.execute("CREATE INDEX notes_meta_id ON notes_meta (id)")
            db.execute("CREATE INDEX notes_meta_rel ON notes_meta (rel)")
            # Lets the commit gate ask "does anything else already supersede X?"
            # without walking every note.
            db.execute("CREATE INDEX notes_meta_supersedes ON notes_meta (supersedes)")
            meta_count = 0
            for path in all_note_paths():
                fm, _err = parse_frontmatter(read_text(path))
                if not fm or not isinstance(fm.get("id"), str) or not fm["id"]:
                    continue
                def _flat(key):
                    v = fm.get(key)
                    return v if isinstance(v, str) else None
                db.execute("INSERT INTO notes_meta (id, rel, status, superseded_by, "
                           "supersedes, review_by, fm_json) VALUES (?,?,?,?,?,?,?)",
                           (fm["id"], str(path.relative_to(K)), _flat("status"),
                            _flat("superseded_by"), _flat("supersedes"),
                            _flat("review_by"), _json_dumps(fm)))
                meta_count += 1
            count = 0
            for r in note_records():
                db.execute(
                    "INSERT INTO fts (title, aliases, topics, body, id, path, folder, "
                    "kind, created) VALUES (?,?,?,?,?,?,?,?,?)",
                    (r["title"], r["aliases"], r["topics"], r["body"], r["id"], r["path"],
                     r["folder"], r["kind"], r["created"]),
                )
                for dst in r["links"]:
                    db.execute("INSERT INTO links (src, dst) VALUES (?,?)", (r["id"], dst))
                count += 1
            db.execute("CREATE INDEX links_dst ON links (dst)")
            db.execute("CREATE INDEX links_src ON links (src)")
            db.commit()
            db.close()
            os.replace(tmp, INDEX_DB)
        finally:
            if tmp.exists():
                tmp.unlink()
    finally:
        lock_file.close()
    if not quiet:
        print(f"brain index: {count} notes indexed -> .cache/index.db")
    return 0


def _json_dumps(obj) -> str:
    import json as _json
    return _json.dumps(obj)


def index_uri() -> str:
    """Read-only URI for the index. as_uri() percent-encodes, so a repo path
    containing spaces or unicode still produces a valid URI."""
    return INDEX_DB.as_uri() + "?mode=ro"


def indexed_count() -> int:
    """Rows currently in the index, or -1 if it cannot be read (forces rebuild)."""
    return indexed_counts()[0]


def indexed_counts() -> tuple:
    """(fts rows, notes_meta rows). -1 for either if it cannot be read, which
    forces a rebuild rather than trusting a database we could not inspect."""
    import sqlite3
    try:
        db = sqlite3.connect(index_uri(), uri=True)
        try:
            fts = db.execute("SELECT COUNT(*) FROM fts").fetchone()[0]
            try:
                meta = db.execute("SELECT COUNT(*) FROM notes_meta").fetchone()[0]
            except sqlite3.OperationalError:
                meta = -1          # index predates notes_meta
            return fts, meta
        finally:
            db.close()
    except Exception:
        return -1, -1


def index_stale() -> bool:
    """Is the derived cache behind the notes?

    Runs before every search and every id lookup, so it walks with os.scandir
    and plain strings: building a Path per note (and sorting them) cost more
    than everything it was guarding. Deliberately checks the WIDER set — the db
    also holds notes_meta over archive/, so archiving a note must invalidate,
    or id resolution keeps serving a path that has since moved.
    """
    import os
    if not INDEX_DB.exists():
        return True
    built = INDEX_DB.stat().st_mtime
    kroot = str(K)
    live = indexable = 0
    stack = [(kroot, None)]
    while stack:
        directory, top = stack.pop()
        try:
            entries = os.scandir(directory)
        except OSError:
            continue
        with entries:
            for entry in entries:
                name = entry.name
                try:
                    if entry.is_dir(follow_symlinks=False):
                        if top is None and name in ("vault", "attachments"):
                            continue
                        stack.append((entry.path, name if top is None else top))
                        continue
                    if not name.lower().endswith(".md"):
                        continue
                    stat = entry.stat()
                except OSError:
                    continue
                live += 1
                if top != "archive" and name not in EXEMPT_NAMES:
                    indexable += 1
                if stat.st_mtime > built:
                    return True
    # Deleting a note changes no surviving file's mtime, so mtime alone cannot
    # see it — without this a deleted note keeps answering searches, pointing
    # at a file that is gone.
    fts_rows, meta_rows = indexed_counts()
    if indexable != fts_rows:
        return True
    # notes_meta only holds notes that HAVE an id, so it is a subset of `live`;
    # more rows than files on disk means notes were removed.
    return meta_rows > live


BM25_WEIGHTS = "8.0, 6.0, 4.0, 1.0, 0, 0, 0, 0, 0"  # title, aliases, topics, body, then UNINDEXED


def do_search(query: str, scope: str = "canonical", limit: int = 8) -> dict:
    """Rank inside SQLite, THEN limit.

    This used to `LIMIT 100` with no ORDER BY and sort those rows in Python.
    FTS5 returns matches in an arbitrary order without ORDER BY, so once more
    than 100 notes matched, the best hit could be discarded before ranking ever
    ran. Folder authority is folded into the SQL ordering expression so the
    ranking that decides the cut is the same one that orders the output.
    """
    import sqlite3
    if index_stale():
        cmd_index(quiet=True, skip_if_fresh=True)
    if not INDEX_DB.exists():          # index could not be built (read-only disk?)
        return {"mode": "none", "hits": [], "more": 0}
    db = sqlite3.connect(index_uri(), uri=True)
    terms = re.findall(r"\w+", query)
    if not terms:
        return {"mode": "empty", "hits": [], "more": 0}
    folders = list(CANONICAL) + (["journal", "inbox"] if scope == "all" else [])
    placeholders = ",".join("?" * len(folders))
    weight_sql = ("CASE folder " + " ".join("WHEN ? THEN ?" for _ in FOLDER_WEIGHTS)
                  + " ELSE 1.0 END")
    weight_params = [v for pair in FOLDER_WEIGHTS.items() for v in pair]
    rows, total, mode = [], 0, "none"
    for joiner, mode_name in ((" AND ", "all-terms"), (" OR ", "any-term")):
        match = joiner.join(f'"{t}"' for t in terms)
        try:
            rows = db.execute(
                f"SELECT id, path, title, folder, kind, created, "
                f"snippet(fts, 3, '[', ']', '…', 14), "
                f"bm25(fts, {BM25_WEIGHTS}) * ({weight_sql}) AS score "
                f"FROM fts WHERE fts MATCH ? AND folder IN ({placeholders}) "
                f"ORDER BY score LIMIT ?",
                (*weight_params, match, *folders, limit),
            ).fetchall()
            if rows:
                total = db.execute(
                    f"SELECT COUNT(*) FROM fts WHERE fts MATCH ? "
                    f"AND folder IN ({placeholders})", (match, *folders)).fetchone()[0]
        except sqlite3.OperationalError:
            rows = []
        if rows:
            mode = mode_name
            break
    if not rows:
        like = f"%{terms[0]}%"
        rows = db.execute(
            f"SELECT id, path, title, folder, kind, created, substr(body, 1, 120), 0.0 "
            f"FROM fts WHERE (title LIKE ? OR body LIKE ?) AND folder IN ({placeholders}) "
            f"ORDER BY folder, id LIMIT ?",
            (like, like, *folders, limit),
        ).fetchall()
        if rows:
            total = db.execute(
                f"SELECT COUNT(*) FROM fts WHERE (title LIKE ? OR body LIKE ?) "
                f"AND folder IN ({placeholders})", (like, like, *folders)).fetchone()[0]
        mode = "substring" if rows else "none"
    hits = [
        {"id": r[0], "path": r[1], "title": r[2], "folder": r[3], "kind": r[4],
         "created": r[5], "snippet": " ".join(str(r[6]).split())}
        for r in rows
    ]
    return {"mode": mode, "hits": hits, "more": max(0, total - len(hits))}


def do_links(note_id: str, rebuild: bool = True) -> dict:
    """The [[wikilink]] neighbourhood of one note: what it points at, and what
    points back at it.

    Backlinks are the half a plain file tree cannot answer: 'what else refers to
    this?' is invisible to grep once a note is referenced by a display alias.
    Returns {"outbound": [...], "inbound": [...], "unresolved": [...]} where
    each entry carries id/title/path when the target is a real indexed note."""
    import sqlite3
    if rebuild and index_stale():
        cmd_index(quiet=True, skip_if_fresh=True)
    elif not rebuild and not INDEX_DB.exists():
        # First-ever use (fresh clone): build once so backlinks work at all.
        # Staleness alone still does NOT trigger a rebuild here — callers like
        # `brain read` must never pay an O(N) reindex just to show context.
        try:
            cmd_index(quiet=True, skip_if_fresh=True)
        except Exception:
            pass
    if not INDEX_DB.exists():
        return {"outbound": [], "inbound": [], "unresolved": [], "available": False}
    try:
        db = sqlite3.connect(index_uri(), uri=True)
    except sqlite3.Error:
        return {"outbound": [], "inbound": [], "unresolved": [], "available": False}
    try:
        def describe(ids):
            found, missing = [], []
            for nid in ids:
                row = db.execute(
                    "SELECT id, title, path, kind, folder FROM fts WHERE id = ? LIMIT 1",
                    (nid,)).fetchone()
                if row:
                    found.append({"id": row[0], "title": row[1], "path": row[2],
                                  "kind": row[3], "folder": row[4]})
                else:
                    missing.append(nid)
            return found, missing

        try:
            out_ids = [r[0] for r in db.execute(
                "SELECT DISTINCT dst FROM links WHERE src = ? ORDER BY dst", (note_id,))]
            in_ids = [r[0] for r in db.execute(
                "SELECT DISTINCT src FROM links WHERE dst = ? ORDER BY src", (note_id,))]
        except sqlite3.OperationalError:
            # Index predates the links table — it will gain one on next rebuild.
            return {"outbound": [], "inbound": [], "unresolved": [], "available": False}
        outbound, unresolved = describe(out_ids)
        inbound, _ = describe(in_ids)
        return {"outbound": outbound, "inbound": inbound, "unresolved": unresolved,
                "available": True}
    finally:
        db.close()


def format_links(note_id: str, result: dict) -> str:
    if not result.get("available"):
        return ("link graph unavailable (no search index yet) — run: bin/brain index")
    lines = [f"# links for {note_id}"]
    if result["inbound"]:
        lines.append(f"\nlinked FROM ({len(result['inbound'])}) — notes that reference this one:")
        for n in result["inbound"]:
            lines.append(f"  <- {n['id']}  {n['title']} ({n['path']})")
    else:
        lines.append("\nlinked FROM: nothing references this note yet")
    if result["outbound"]:
        lines.append(f"\nlinks TO ({len(result['outbound'])}):")
        for n in result["outbound"]:
            lines.append(f"  -> {n['id']}  {n['title']} ({n['path']})")
    else:
        lines.append("\nlinks TO: none")
    if result["unresolved"]:
        lines.append(f"\nUNRESOLVED targets ({len(result['unresolved'])}) — these point at no "
                     "current note (superseded, archived, or a typo):")
        for nid in result["unresolved"]:
            lines.append(f"  -> [[{nid}]]  ?")
    return "\n".join(lines)


def cmd_links(argv: list) -> int:
    import json as _json
    args = [a for a in argv if not a.startswith("--")]
    if not args:
        print("usage: brain links <id-or-path> [--json]")
        return 2
    wanted = args[0]
    metas = all_metas()
    note_id = wanted
    if wanted not in metas:
        # Accept a path too, so `brain links knowledge/decisions/x.md` works.
        candidate = resolve_note_path(wanted)
        if candidate is not None:
            fm, _err = parse_frontmatter(read_text(candidate))
            if fm and fm.get("id"):
                note_id = str(fm["id"])
        if note_id == wanted and wanted not in metas:
            print(f"note {wanted!r} not found (by id or path)")
            return 1
    result = do_links(note_id)
    print(_json.dumps(result, indent=2) if "--json" in argv
          else format_links(note_id, result))
    return 0


def format_hits(result: dict) -> str:
    if not result["hits"]:
        return ("no hits — rewrite the query into 2-3 lexical variants (synonyms, "
                "singular/plural) before concluding the brain has nothing")
    lines = []
    for i, h in enumerate(result["hits"], 1):
        tag = ""
        if h["folder"] == "inbox":
            tag = " [provisional — unconsolidated]"
        elif h["folder"] == "journal":
            tag = " [journal]"
        lines.append(f"{i}. {h['path']} — {h['title']} ({h['kind']}, {h['created'] or 'n/a'}){tag}")
        if h["snippet"]:
            lines.append(f"   {h['snippet']}")
    if result["more"]:
        lines.append(f"({result['more']} more hits below the cap — narrow the query to see them)")
    lines.append(f"[match mode: {result['mode']}]")
    return "\n".join(lines)


def cmd_search(argv: list) -> int:
    import json as _json
    scope, limit, as_json, terms = "canonical", 8, False, []
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--scope" and i + 1 < len(argv):
            scope = argv[i + 1]
            i += 2
        elif a == "--limit" and i + 1 < len(argv):
            try:
                limit = max(1, int(argv[i + 1]))
            except ValueError:
                pass
            i += 2
        elif a == "--json":
            as_json = True
            i += 1
        elif a == "--":
            # End of options: everything after is query text, so a search for
            # "--scope" finds notes about --scope instead of silently parsing
            # it as a flag and searching for nothing.
            terms.extend(argv[i + 1:])
            break
        elif a.startswith("--"):
            i += 1
        else:
            terms.append(a)
            i += 1
    if scope not in ("canonical", "all"):
        scope = "canonical"
    if not terms:
        print("usage: brain search \"<query>\" [--scope canonical|all] [--limit N] [--json]")
        return 2
    result = do_search(" ".join(terms), scope=scope, limit=limit)
    print(_json.dumps(result, indent=2) if as_json else format_hits(result))
    return 0


def all_metas_scan() -> dict:
    """Authoritative id -> (rel, frontmatter) map, read from the notes themselves."""
    metas = {}
    for rel, (fm, _err) in collect_notes().items():
        if fm and fm.get("id"):
            metas[fm["id"]] = (rel, fm)
    return metas


def all_metas() -> dict:
    """id -> (rel, frontmatter) for every note, served from .cache when fresh.

    Re-reading and re-parsing every note just to turn one id into one path made
    `brain read` — the verb every retrieval flow ends in — scale with the size
    of the whole brain. The cache is only ever a FAST PATH: it is used solely
    when the index is fresh (same check that guards search), and any failure to
    read it falls through to the authoritative scan. Notes remain the truth;
    this is derived and disposable like every other index here.
    """
    import json as _json
    import sqlite3
    try:
        if index_stale() or not INDEX_DB.exists():
            return all_metas_scan()
        db = sqlite3.connect(index_uri(), uri=True)
        try:
            rows = db.execute("SELECT id, rel, fm_json FROM notes_meta").fetchall()
        finally:
            db.close()
    except Exception:
        return all_metas_scan()
    if not rows:
        # An empty table on a repo that clearly has notes means the cache was
        # built by an older version; don't hand back an empty brain.
        return all_metas_scan()
    metas = {}
    try:
        for note_id, rel, fm_json in rows:
            metas[note_id] = (Path(rel), _json.loads(fm_json))
    except (ValueError, TypeError):
        return all_metas_scan()
    return metas


class MetaIndex:
    """id/path lookups for single notes, O(1) against .cache when it is fresh.

    `brain read` needs one id and the two or three hops of its supersede chain —
    never the whole corpus — so materialising every note's frontmatter to answer
    it was the wrong shape. This resolves one row at a time and degrades to the
    authoritative full scan the moment the cache is missing, stale or
    unreadable, so a cold or broken .cache costs speed, never correctness.
    """

    def __init__(self, require_fresh: bool = True):
        self._db = None
        self._fallback = None
        import sqlite3
        try:
            if not INDEX_DB.exists() or (require_fresh and index_stale()):
                raise RuntimeError("stale")
            db = sqlite3.connect(index_uri(), uri=True)
            db.execute("SELECT 1 FROM notes_meta LIMIT 1").fetchone()
            self._db = db
        except Exception:
            self._fallback = all_metas_scan()

    def _row(self, sql, args):
        import json as _json
        try:
            row = self._db.execute(sql, args).fetchone()
        except Exception:
            return None
        if not row:
            return None
        try:
            return Path(row[0]), _json.loads(row[1])
        except (ValueError, TypeError):
            return None

    def get(self, note_id):
        """(rel, frontmatter) for an id, or None."""
        if self._db is None:
            return self._fallback.get(note_id)
        return self._row("SELECT rel, fm_json FROM notes_meta WHERE id = ? LIMIT 1",
                         (note_id,))

    def by_rel(self, rel):
        """(id, rel, frontmatter) for a knowledge/-relative path, or None."""
        if self._db is None:
            for note_id, (nrel, fm) in self._fallback.items():
                if nrel == rel:
                    return note_id, nrel, fm
            return None
        import json as _json
        try:
            row = self._db.execute(
                "SELECT id, rel, fm_json FROM notes_meta WHERE rel = ? LIMIT 1",
                (str(rel),)).fetchone()
        except Exception:
            return None
        if not row:
            return None
        try:
            return row[0], Path(row[1]), _json.loads(row[2])
        except (ValueError, TypeError):
            return None

    def exists(self, note_id) -> bool:
        if self._db is None:
            return note_id in self._fallback
        try:
            return self._db.execute("SELECT 1 FROM notes_meta WHERE id = ? LIMIT 1",
                                    (note_id,)).fetchone() is not None
        except Exception:
            return False

    def get_all(self, note_id) -> list:
        """EVERY row recorded for an id, not just one.

        An id can legitimately appear more than once here — that is exactly the
        state duplicate detection exists to catch — so a LIMIT 1 lookup can hand
        back the very row the caller is trying to look past."""
        import json as _json
        if self._db is None:
            hit = self._fallback.get(note_id)
            return [hit] if hit else []
        try:
            rows = self._db.execute(
                "SELECT rel, fm_json FROM notes_meta WHERE id = ?", (note_id,)).fetchall()
        except Exception:
            return []
        out = []
        for rel, fm_json in rows:
            try:
                out.append((Path(rel), _json.loads(fm_json)))
            except (ValueError, TypeError):
                continue
        return out

    def who_supersedes(self, target_id) -> list:
        """Ids of notes claiming `supersedes: target_id`. A column lookup, so
        the gate can detect a forked supersede without reading every note."""
        if self._db is None:
            return [nid for nid, (_rel, fm) in self._fallback.items()
                    if fm.get("supersedes") == target_id]
        try:
            return [r[0] for r in self._db.execute(
                "SELECT id FROM notes_meta WHERE supersedes = ?", (target_id,))]
        except Exception:
            return []

    def overdue(self, today_iso) -> list:
        """Ids whose review_by has passed — a column query, never a full parse."""
        if self._db is None:
            return [nid for nid, (_rel, fm) in self._fallback.items()
                    if fm.get("review_by") and str(fm["review_by"]) < today_iso]
        try:
            return [r[0] for r in self._db.execute(
                "SELECT id FROM notes_meta WHERE review_by IS NOT NULL AND review_by < ?",
                (today_iso,))]
        except Exception:
            return []

    def close(self):
        if self._db is not None:
            try:
                self._db.close()
            except Exception:
                pass


def resolve_note_path(wanted: str):
    """Resolve a path request to a real .md file strictly INSIDE knowledge/, else None.

    brain_read is exposed to any Claude session over MCP, so this is a trust
    boundary, not a convenience: resolve() collapses '..' and follows symlinks,
    then relative_to() proves the real target still sits under knowledge/. A
    path that escapes — 'knowledge/../../secrets', an absolute path, a symlink
    pointing out of the tree — resolves outside K and is refused here.
    """
    raw = Path(wanted)
    if raw.is_absolute():
        candidate = raw
    else:
        # Accept both 'knowledge/x.md' and bare 'x.md' forms.
        rel = Path(*raw.parts[1:]) if raw.parts and raw.parts[0] == "knowledge" else raw
        candidate = K / rel
    try:
        real = candidate.resolve()
        real.relative_to(K.resolve())
    except (ValueError, OSError, RuntimeError):
        return None
    if not real.is_file() or real.suffix.lower() != ".md":
        return None
    return real


def cmd_read(argv: list) -> int:
    args = [a for a in argv if not a.startswith("--")]
    if not args:
        print("usage: brain read <id-or-path>")
        return 2
    wanted = args[0]
    metas = MetaIndex()
    target_id = None
    if metas.get(wanted) is not None:
        target_id = wanted
    else:
        p = Path(wanted)
        try:
            rel = (ROOT / p).resolve().relative_to(K) if not str(p).startswith("knowledge/") \
                else Path(*Path(wanted).parts[1:])
        except ValueError:
            rel = None
        if rel is not None:
            found = metas.by_rel(rel)
            if found:
                target_id = found[0]
    if target_id is None:
        candidate = resolve_note_path(wanted)
        if candidate is not None:
            # Notes with no frontmatter id (inbox captures, journal entries)
            # reach here. They are provisional/dated, never canonical — say so
            # before dumping the body, exactly as the id path does below.
            try:
                top = candidate.resolve().relative_to(K.resolve()).parts[0]
            except (ValueError, OSError):
                top = ""
            if top == "inbox":
                print("WARNING: this is an INBOX capture — PROVISIONAL, not consolidated "
                      "knowledge. Do not present it as settled.\n")
            elif top == "journal":
                print("NOTE: this is a JOURNAL entry — a dated observation, not canonical "
                      "knowledge.\n")
            elif top == "archive":
                print("WARNING: this note is ARCHIVED/superseded — HISTORY, not current. "
                      "Cite it only as 'previously…'.\n")
            print(read_text(candidate))
            return 0
        print(f"note {wanted!r} not found (by id or path)")
        return 1

    chain = []
    seen = set()
    current_id = target_id
    while True:
        rel, fm = metas.get(current_id)
        successor = fm.get("superseded_by")
        if fm.get("status") == "superseded" and current_id not in seen \
                and isinstance(successor, str) and metas.get(successor) is not None:
            seen.add(current_id)
            chain.append(current_id)
            current_id = successor
        else:
            break
    rel, fm = metas.get(current_id)
    # Same trust boundary as the path branch: a note reached by id is still
    # read off disk, and a symlinked .md inside knowledge/ would otherwise
    # hand back whatever it points at.
    body_path = resolve_note_path(str(K / rel))
    if body_path is None:
        print(f"note {current_id!r} resolves outside knowledge/ — refused")
        return 1
    print(f"# {fm.get('title')}  ({fm.get('kind')}, created {fm.get('created')}, status {fm.get('status')})")
    print(f"path: knowledge/{rel}")
    if chain:
        print(f"NOTE: {wanted!r} was superseded — this is the CURRENT version. "
              f"Chain: {' -> '.join(chain + [current_id])}")
    if fm.get("supersedes"):
        print(f"history: supersedes [[{fm['supersedes']}]] (archived)")
    # Surface staleness/provenance the caller cannot see from the body alone, so
    # a model never presents unverified or historical content as settled truth.
    top = rel.parts[0]
    if top == "archive" or fm.get("status") == "superseded":
        print("WARNING: this note is ARCHIVED/superseded — it is HISTORY, not current. "
              "Cite it only as 'previously…', never as true today.")
    elif top == "inbox":
        print("WARNING: this is an INBOX capture — PROVISIONAL, not consolidated knowledge. "
              "Do not present it as settled.")
    elif top == "journal":
        print("NOTE: this is a JOURNAL entry — a dated observation, not canonical knowledge.")
    review_by = fm.get("review_by")
    if review_by and str(review_by) < date.today().isoformat():
        print(f"WARNING: review_by {review_by} has passed — this fact may be STALE; verify "
              "before relying on it.")
    # Backlinks: the context a lone note body cannot carry — what else in the
    # brain refers to this. Never triggers an index rebuild; a stale or missing
    # index simply means no graph line, not a slow read.
    graph = do_links(current_id, rebuild=False)
    if graph.get("inbound"):
        refs = ", ".join(f"[[{n['id']}]]" for n in graph["inbound"][:12])
        more = "" if len(graph["inbound"]) <= 12 else f" (+{len(graph['inbound']) - 12} more)"
        print(f"linked from ({len(graph['inbound'])}): {refs}{more}")
    print()
    print(read_text(body_path))
    return 0


def cmd_recent(argv: list) -> int:
    days = 7
    for i, a in enumerate(argv):
        if a == "--days" and i + 1 < len(argv):
            try:
                days = max(1, int(argv[i + 1]))
            except ValueError:
                print(f"--days needs an integer, got {argv[i + 1]!r}")
                return 2
    cutoff = time.time() - days * 86400
    rows = []
    for path in K.rglob("*.md"):
        top = path.relative_to(K).parts[0]
        if top in ("archive", "vault") or path.name in EXEMPT_NAMES:
            continue
        if path.stat().st_mtime >= cutoff:
            rows.append((path.stat().st_mtime, path))
    if not rows:
        print(f"no notes touched in the last {days} day(s)")
        return 0
    for mtime, path in sorted(rows, reverse=True)[:30]:
        day = time.strftime("%Y-%m-%d", time.localtime(mtime))
        print(f"{day}  {path.relative_to(ROOT)}")
    return 0


def fm_update(path: Path, updates: dict, banner: str = None) -> None:
    """Set flat frontmatter fields in place (add if missing); optionally insert a
    banner line right after the frontmatter block."""
    lines = read_text(path).splitlines()
    end = next(i for i in range(1, len(lines)) if lines[i].strip() == "---")
    done = set()
    for i in range(1, end):
        m = re.match(r"^([A-Za-z_][A-Za-z0-9_]*):", lines[i])
        if m and m.group(1) in updates:
            lines[i] = f"{m.group(1)}: {updates[m.group(1)]}"
            done.add(m.group(1))
    for key, value in updates.items():
        if key not in done:
            lines.insert(end, f"{key}: {value}")
            end += 1
    if banner:
        lines.insert(end + 1, "")
        lines.insert(end + 2, banner)
    path.write_text("\n".join(lines) + "\n", encoding="utf-8")


def cmd_supersede(argv: list) -> int:
    args = [a for a in argv if not a.startswith("--")]
    if len(args) < 2:
        print('usage: brain supersede <old-id> "<new title>" [--topics a,b]')
        return 2
    old_id, title = args[0], args[1]
    metas = all_metas()
    if old_id not in metas:
        print(f"note {old_id!r} not found")
        return 1
    old_rel, old_fm = metas[old_id]
    if old_rel.parts[0] == "archive":
        print(f"{old_id!r} is already archived (superseded_by: "
              f"{old_fm.get('superseded_by')})")
        return 1
    folder = old_rel.parts[0]
    kind = FOLDER_KIND.get(folder)
    if kind == "project":
        print("projects are containers, not single facts — supersede a specific note "
              "inside the project instead")
        return 1

    topics_arg = ""
    for i, a in enumerate(argv):
        if a == "--topics" and i + 1 < len(argv):
            topics_arg = argv[i + 1]
    old_topics = old_fm.get("topics") or []
    if not isinstance(old_topics, list):
        old_topics = [old_topics]
    chosen = ([t.strip() for t in topics_arg.split(",") if t.strip()] or old_topics)

    today = date.today().isoformat()
    slug = slugify(title)
    new_id = unique_id(f"{today}-{slug}" if kind == "decision" else slug)
    new_path = K / folder / f"{new_id}.md"
    dest = K / "archive" / old_rel

    # unique_id() only guarantees the frontmatter *id* is free; it says nothing
    # about the file *path*, and lint never requires filename==id. Writing over
    # an existing note here would silently destroy its body (the template is
    # blank), and overwriting an archived note would rewrite append-only
    # history — both forbidden by CLAUDE.md. Refuse before touching disk.
    if new_path.exists():
        print(f"a note already exists at {new_path.relative_to(ROOT)} — superseding would "
              "overwrite its content. Choose a different title.")
        return 1
    if dest.exists():
        print(f"{dest.relative_to(ROOT)} already exists — archive history is append-only and "
              "must never be overwritten. Resolve that first.")
        return 1

    new_path.write_text(
        render_template(kind, {
            "ID": new_id, "TITLE": title, "DATE": today,
            "TOPICS": ", ".join(chosen),
            "SENSITIVITY": old_fm.get("sensitivity") or "normal",
        }),
        encoding="utf-8",
    )
    fm_update(new_path, {"supersedes": old_id})

    old_path = K / old_rel
    fm_update(old_path, {"status": "superseded", "superseded_by": new_id},
              banner=f"> SUPERSEDED {today} by [[{new_id}]] — <one-line reason>")
    dest.parent.mkdir(parents=True, exist_ok=True)
    moved = subprocess.run(["git", "mv", str(old_path), str(dest)], cwd=ROOT,
                           capture_output=True, text=True)
    if moved.returncode != 0:
        # git mv can fail for benign reasons (path not yet tracked); fall back to
        # a plain move — but never over an existing archive file (history is
        # append-only), which could have appeared since the guard above.
        if dest.exists():
            print(f"git mv failed and {dest.relative_to(ROOT)} now exists — refusing to "
                  f"overwrite history. The new note {new_path.relative_to(ROOT)} was created; "
                  "move the old note into archive/ by hand.")
            return 1
        old_path.replace(dest)

    print(f"created:  {new_path}")
    print(f"archived: {dest}")
    tail = ("" if kind == "decision" else
            f" The previous content is preserved in {dest.relative_to(ROOT)} — copy across "
            "whatever still holds (supersede starts the new note from a blank template).")
    print("now: fill the new note's body and aliases, replace the '<one-line reason>' "
          "in the archived note's banner, run bin/brain lint, then commit." + tail)
    return 0


TRANSCRIPT_ROOT = Path.home() / ".claude" / "projects"

# Wrapper turns the CLI injects into the transcript as if they were typed.
_NOISE_PREFIXES = ("<local-command", "<command-name>", "<command-message>",
                   "<command-args>", "<bash-input>", "<bash-stdout>", "Caveat:")
_REMINDER_RE = re.compile(r"<system-reminder>.*?</system-reminder>", re.S)


def digest_path() -> Path:
    # Computed, not a module constant: main() rebinds ROOT for --root.
    return ROOT / ".cache" / "session-digest.md"


def _human_turns(path: Path, max_turn: int = 2000) -> tuple:
    """(timestamp, text) pairs for the user's OWN prompts in one transcript, + cwd.

    Assistant output is deliberately never extracted. The point of mining is to
    recover what the user decided, preferred and knew; feeding my own prose back
    into the brain would launder my speculation into their recorded fact.
    """
    import json as _json
    turns, cwd = [], ""
    try:
        raw = path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return [], ""
    for line in raw.splitlines():
        if not line.strip():
            continue
        try:
            rec = _json.loads(line)
        except ValueError:
            continue
        if not isinstance(rec, dict) or rec.get("type") != "user":
            continue
        if rec.get("isSidechain"):
            continue                       # subagent traffic, not the user
        msg = rec.get("message")
        content = msg.get("content") if isinstance(msg, dict) else None
        if not isinstance(content, str):
            continue                       # list content == tool results
        cwd = cwd or str(rec.get("cwd") or "")
        text = _REMINDER_RE.sub("", content).strip()
        if not text or text.startswith(_NOISE_PREFIXES):
            continue
        if len(text) > max_turn:
            text = text[:max_turn] + " …[truncated]"
        turns.append((str(rec.get("timestamp") or "")[:19], text))
    return turns, cwd


def session_digest(days: int = 8, max_chars: int = 120_000) -> tuple:
    """(markdown, session_count) of recent human turns across all projects.

    Transcripts live outside the repo, so the consolidation model — which runs
    headless and cannot answer a permission prompt — could not read them
    itself. The wrapper materializes them into .cache/ (gitignored) first.
    """
    cutoff = time.time() - days * 86400
    # Transcript timestamps are ISO-8601 UTC, so lexical compare == chronological.
    cutoff_iso = time.strftime("%Y-%m-%dT%H:%M:%S", time.gmtime(cutoff))
    sessions = []
    if TRANSCRIPT_ROOT.is_dir():
        for path in sorted(TRANSCRIPT_ROOT.glob("*/*.jsonl")):
            try:
                mtime = path.stat().st_mtime
            except OSError:
                continue
            if mtime < cutoff:
                continue          # cheap pre-filter: mtime >= every turn in it
            turns, cwd = _human_turns(path)
            if not turns:
                continue
            # The real filter is when the user actually TALKED. A file merely
            # touched recently (reindexed, copied) can hold a months-old
            # conversation, and mining those would resurrect them every week.
            newest = max(ts for ts, _ in turns)
            if newest < cutoff_iso:
                continue
            sessions.append((newest, cwd, turns))

    sessions.sort(key=lambda s: s[0], reverse=True)   # trim the oldest first
    blocks, used, kept = [], 0, 0
    for newest, cwd, turns in sessions:
        head = f"\n## {newest[:10]} — {cwd or 'unknown directory'}\n"
        # Blockquote every line: prompts often contain their own "## " headings,
        # which would otherwise be indistinguishable from a session boundary.
        body = "".join(
            "\n**[{}]**\n{}\n".format(ts, "\n".join("> " + ln for ln in text.splitlines()))
            for ts, text in turns)
        if used + len(head) + len(body) > max_chars and kept:
            break
        blocks.append((newest, head + body))
        used += len(head) + len(body)
        kept += 1

    blocks.sort(key=lambda b: b[0])                   # present chronologically
    dropped = len(sessions) - kept
    header = (f"# Session digest — {kept} session(s), last {days} days\n\n"
              "The user's own prompts only; assistant output is excluded by design.\n"
              "Provisional raw material for consolidation, not knowledge itself.\n")
    if dropped:
        header += f"\nNOTE: {dropped} older session(s) dropped at the size cap.\n"
    if not kept:
        header += "\nNo sessions in the window — nothing to mine.\n"
    return header + "".join(b for _, b in blocks), kept


def cmd_sessions(argv: list) -> int:
    days = 8
    for i, arg in enumerate(argv):
        if arg == "--days" and i + 1 < len(argv):
            try:
                days = max(1, int(argv[i + 1]))
            except ValueError:
                print("--days needs an integer")
                return 2
    text, count = session_digest(days=days)
    if "--stdout" in argv:
        print(text)
        return 0
    out = digest_path()
    out.parent.mkdir(parents=True, exist_ok=True)
    out.write_text(text, encoding="utf-8")
    print(f"session digest: {count} session(s), {len(text)} chars → {out}")
    if not count and not TRANSCRIPT_ROOT.is_dir():
        print(f"(no transcripts at {TRANSCRIPT_ROOT})")
    return 0


def cmd_consolidate(argv: list) -> int:
    prompt_path = ROOT / "setup" / "consolidate-prompt.md"
    if not prompt_path.exists():
        print("missing setup/consolidate-prompt.md")
        return 1
    inbox_items = [p for p in (K / "inbox").glob("*.md")]
    if "--dry-run" in argv:
        print(f"would consolidate: {len(inbox_items)} inbox item(s)")
        _, sessions = session_digest()
        print(f"would mine: {sessions} recent session(s)")
        print(f"prompt: {prompt_path}")
        return 0
    if git("status", "--porcelain").strip():
        print("working tree not clean — commit or stash first, then rerun")
        return 1
    today = date.today().isoformat()
    branch = f"consolidate/{today}"
    if git("branch", "--list", branch):
        branch = f"{branch}-{time.strftime('%H%M')}"
    subprocess.run(["git", "checkout", "-b", branch], cwd=ROOT, check=True)
    print(f"brain consolidate: running Claude on branch {branch} (model pinned)…")

    # Materialize the session digest BEFORE handing over: the model runs
    # headless and cannot approve reads outside the repo. A failure here is not
    # fatal — draining the inbox is still worth doing on its own.
    try:
        text, sessions = session_digest()
        digest_path().parent.mkdir(parents=True, exist_ok=True)
        digest_path().write_text(text, encoding="utf-8")
        print(f"  session digest: {sessions} session(s) → {digest_path()}")
    except Exception as exc:
        print(f"  session digest skipped: {exc!r}")
        try:
            digest_path().unlink()     # never let LAST week's digest be re-mined
        except OSError:
            pass

    # Every stage is gated on the previous one succeeding. This used to run the
    # commit and the push from a `finally:`, so a model that crashed, timed out
    # or wrote garbage still got its work committed AND pushed, and the closing
    # message claimed the consolidation had landed either way.
    failure = None
    try:
        run = subprocess.run(
            ["claude", "--model", "claude-opus-4-8", "--permission-mode", "acceptEdits",
             "-p", prompt_path.read_text(encoding="utf-8")],
            cwd=ROOT, text=True, capture_output=True, timeout=1800,
        )
        print(run.stdout[-2000:] if run.stdout else "(no output)")
        if run.returncode != 0:
            failure = (f"claude exited {run.returncode}: "
                       f"{(run.stderr or '').strip()[-300:] or 'no stderr'}")
    except subprocess.TimeoutExpired:
        failure = "claude timed out after 1800s"
    except (OSError, subprocess.SubprocessError) as exc:
        failure = f"could not run claude: {exc!r}"

    dirty = bool(git("status", "--porcelain").strip())
    try:
        lint_code = lint()
    except Exception as exc:
        lint_code = 1
        failure = failure or f"lint crashed on the consolidated tree: {exc!r}"
    if lint_code != 0 and failure is None:
        failure = "lint rejected the consolidated tree"

    committed = pushed = False
    if failure is None and dirty:
        subprocess.run(["git", "add", "-A"], cwd=ROOT, capture_output=True)
        commit = subprocess.run(["git", "commit", "-m", f"consolidate: {today}"],
                                cwd=ROOT, capture_output=True, text=True)
        committed = commit.returncode == 0
        if not committed:
            failure = (f"commit rejected: "
                       f"{(commit.stderr or commit.stdout).strip()[-300:] or 'unknown'}")
    if committed:
        push = subprocess.run(["git", "push", "-u", "origin", branch],
                              cwd=ROOT, capture_output=True, text=True)
        pushed = push.returncode == 0

    # Only step off the branch when nothing would be carried along with us.
    if not git("status", "--porcelain").strip():
        subprocess.run(["git", "checkout", "main"], cwd=ROOT, capture_output=True)
    here = git("rev-parse", "--abbrev-ref", "HEAD") or "?"

    print()
    if failure:
        print(f"consolidation DID NOT LAND: {failure}")
        print(f"nothing was committed or pushed; the work is left on {branch} "
              f"{'(uncommitted) ' if dirty else ''}for inspection")
        print(f"you are on branch: {here}")
        return 1
    if not dirty:
        print("consolidation made no changes — nothing to review")
        return 0
    print(f"consolidation committed on {branch} (never on main)"
          + ("" if pushed else " — PUSH FAILED, run: git push -u origin " + branch))
    print(f"review:  git diff main...{branch}")
    print(f"merge:   git merge {branch} && git push")
    return 0


# Paths relative to knowledge/ — the scaffolding a brain needs to exist, as
# opposed to anything the owner has actually written down. note-conventions is
# documentation of the system rather than knowledge about its owner, and an
# entirely empty brain is a bad first experience: a new user gets one worked
# example of a correct note instead of a blank folder.
TEMPLATE_KEEP_KNOWLEDGE = ("index.md", "topics.yaml", "vault/README.md",
                           "reference/note-conventions.md")
TEMPLATE_DROP = (
    "setup/vault-recipient.txt",   # the AUTHOR's age key — a stranger encrypting
                                   # to it could never read their own vault back
    ".mcp.json",                   # machine-local absolute paths
    "setup/skills/brain/SKILL.md",  # rendered per machine by `brain init`
    ".claude/settings.local.json",  # this machine's local Claude permissions
)


def cmd_template(argv: list) -> int:
    """Emit a publishable copy of this system with none of the owner's knowledge.

    The public template used to be a SEPARATE repo kept in sync by hand, which
    is the same mistake this project refuses everywhere else: two sources of
    truth. Here the template is DERIVED — regenerate it, never edit it — so a
    fix to the toolbelt can never be live in one and missing in the other.

    What ships: the toolbelt, hooks, CI, tests, docs and the folder skeleton.
    What never ships: a single one of your notes, your vault recipient, or any
    machine-local wiring.
    """
    import shutil
    args = [a for a in argv if not a.startswith("--")]
    if not args:
        print("usage: brain template <destination-dir> [--force]")
        return 2
    dest = Path(args[0]).expanduser().resolve()
    if dest.exists() and any(dest.iterdir()):
        if "--force" not in argv:
            print(f"{dest} exists and is not empty — refusing to overwrite. "
                  "Pass --force to replace its contents.")
            return 1
        shutil.rmtree(dest)
    if str(dest) == str(ROOT) or str(ROOT).startswith(str(dest) + "/"):
        print("refusing to write the template over this repo")
        return 1

    skip_dirs = {".git", ".cache", "__pycache__", "node_modules", "graphify-out"}
    copied = 0
    for src in ROOT.rglob("*"):
        rel = src.relative_to(ROOT)
        if set(rel.parts) & skip_dirs or src.is_symlink() or not src.is_file():
            continue
        if src.name == ".DS_Store" or src.name.endswith(".local.md"):
            continue
        if str(rel) in TEMPLATE_DROP:
            continue
        # knowledge/ ships as an empty skeleton: structure and vocabulary, no
        # notes. Compare against the path RELATIVE TO knowledge/, which is how
        # TEMPLATE_KEEP_KNOWLEDGE is written.
        if rel.parts[0] == "knowledge":
            in_knowledge = str(Path(*rel.parts[1:])) if len(rel.parts) > 1 else ""
            if in_knowledge not in TEMPLATE_KEEP_KNOWLEDGE and src.name != ".gitkeep":
                continue
        target = dest / rel
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(src, target)
        copied += 1
    print(f"  [1/4] copied {copied} file(s): toolbelt, hooks, CI, tests, docs")

    # Keep every canonical folder present so a fresh brain has somewhere to put
    # its first note, and git actually tracks the empty directories.
    skeleton = list(CANONICAL) + ["inbox", "journal", "archive", "vault", "attachments"]
    for folder in skeleton:
        d = dest / "knowledge" / folder
        d.mkdir(parents=True, exist_ok=True)
        keep = d / ".gitkeep"
        if not any(d.iterdir()):
            keep.write_text("", encoding="utf-8")
    # The route map ships, but its hub list describes THIS brain — and every
    # [[link]] in it would dangle in an empty one, which lint rightly rejects.
    route_map = dest / "knowledge" / "index.md"
    if route_map.exists():
        text = route_map.read_text(encoding="utf-8")
        head = text.split("## Topic hubs")[0].rstrip()
        route_map.write_text(
            head + "\n\n## Topic hubs\n\n"
            "Link your hub pages here as you create them, so this stays a "
            "one-hop route\nmap to everything else:\n\n"
            "- (none yet — `bin/brain new topic \"...\" --topics ...` creates the "
            "first one)\n", encoding="utf-8")
    # A shipped note may cite notes that stay behind. Those [[links]] would
    # dangle in the template — which lint rightly refuses — so demote any target
    # that is not itself shipped to plain text.
    shipped_ids = set()
    for path in (dest / "knowledge").rglob("*.md"):
        fm, _err = parse_frontmatter(path.read_text(encoding="utf-8", errors="replace"))
        if fm and isinstance(fm.get("id"), str):
            shipped_ids.add(fm["id"])
    for path in (dest / "knowledge").rglob("*.md"):
        text = path.read_text(encoding="utf-8", errors="replace")
        rewritten = text
        for target in extract_links(text):
            if target not in shipped_ids:
                rewritten = rewritten.replace(f"[[{target}]]", target)
        if rewritten != text:
            path.write_text(rewritten, encoding="utf-8")
    print(f"  [2/4] knowledge/ reset to a starter skeleton "
          f"({len(skeleton)} folders, index.md + topics.yaml + 1 example note)")

    # Prove it: no note bodies, no owner key, no machine-local wiring, no secrets.
    leaks = []
    for path in dest.rglob("*"):
        if not path.is_file() or set(path.relative_to(dest).parts) & skip_dirs:
            continue
        rel = str(path.relative_to(dest))
        if rel in TEMPLATE_DROP:
            leaks.append(f"{rel} should not have shipped")
        try:
            text = path.read_text(encoding="utf-8-sig", errors="replace")
        except OSError:
            continue
        if secret_screen(text):
            probe: list = []
            scan_secrets(path, probe)
            for _p, msg in probe:
                leaks.append(f"{rel}: {msg}")
    notes_shipped = [str(p.relative_to(dest / "knowledge"))
                     for p in (dest / "knowledge").rglob("*.md")
                     if str(p.relative_to(dest / "knowledge")) not in TEMPLATE_KEEP_KNOWLEDGE]
    leaks += [f"knowledge/{n} is one of your notes — it must not ship" for n in notes_shipped]
    if leaks:
        print("  [3/4] REFUSING TO PUBLISH — the template is not clean:")
        for leak in leaks:
            print(f"        - {leak}")
        return 1
    print("  [3/4] scanned for notes, keys and secrets ........ clean")

    check = subprocess.run([sys.executable, str(dest / "bin" / "brain"), "lint"],
                           cwd=dest, capture_output=True, text=True)
    if check.returncode != 0:
        print("  [4/4] LINT FAILED on the generated template:")
        print("\n".join("        " + l for l in check.stdout.splitlines()[-12:]))
        return 1
    print("  [4/4] lint ...................................... clean")
    print(f"\ntemplate ready: {dest}")
    print("publish it with a FRESH history (never reuse this repo's):")
    print(f"  cd {dest} && git init && git add -A && git commit -m 'second brain template'")
    print("  gh repo create <name> --public --source . --push")
    print("  then mark it as a template repository in GitHub's settings")
    return 0


PLIST_DIR = Path.home() / "Library" / "LaunchAgents"
SCHEDULES = {"doctor": "com.secondbrain.doctor", "consolidate": "com.secondbrain.consolidate"}
# Historical launchd labels from before this system was generalised. They are
# kept verbatim ONLY so a machine that installed an earlier release gets its old
# jobs unloaded: install and uninstall both clear them, or that machine quietly
# runs two doctors and two weekly consolidations forever. Nothing new is ever
# created under these names — see SCHEDULES above for the labels in use.
LEGACY_SCHEDULE_LABELS = ("com.monta.brain-doctor", "com.monta.brain-consolidate")


def remove_legacy_schedules() -> list:
    """Unload and delete any pre-rename launchd jobs. Returns what was removed."""
    removed = []
    for label in LEGACY_SCHEDULE_LABELS:
        plist = PLIST_DIR / f"{label}.plist"
        if plist.exists():
            subprocess.run(["launchctl", "unload", str(plist)], capture_output=True)
            try:
                plist.unlink()
                removed.append(label)
            except OSError:
                pass
    return removed


def cmd_schedule(argv: list) -> int:
    action = argv[0] if argv else "status"
    if action == "status":
        for name, label in SCHEDULES.items():
            installed = (PLIST_DIR / f"{label}.plist").exists()
            print(f"  {name}: {'installed' if installed else 'not installed'}")
        return 0
    if action not in ("install", "uninstall"):
        print("usage: brain schedule install [--with-consolidate] | uninstall | status")
        return 2
    targets = ["doctor"]
    if "--with-consolidate" in argv:
        targets.append("consolidate")
    if action == "uninstall":
        targets = list(SCHEDULES)
    # Migration: clear pre-rename jobs on BOTH paths, so installing never leaves
    # a duplicate scheduler behind and uninstalling really does remove everything.
    for label in remove_legacy_schedules():
        print(f"removed legacy schedule: {label}")
    for name in targets:
        label = SCHEDULES[name]
        plist = PLIST_DIR / f"{label}.plist"
        if action == "uninstall":
            subprocess.run(["launchctl", "unload", str(plist)], capture_output=True)
            if plist.exists():
                plist.unlink()
            print(f"removed schedule: {name}")
            continue
        template = (ROOT / "setup" / "schedules" / f"{label}.plist.template").read_text(encoding="utf-8")
        rendered = (template
                    .replace("{{PYTHON}}", sys.executable)
                    .replace("{{REPO}}", str(ROOT))
                    .replace("{{HOME}}", str(Path.home())))
        PLIST_DIR.mkdir(parents=True, exist_ok=True)
        plist.write_text(rendered, encoding="utf-8")
        subprocess.run(["launchctl", "unload", str(plist)], capture_output=True)
        subprocess.run(["launchctl", "load", str(plist)], capture_output=True)
        print(f"installed schedule: {name} ({plist})")
    return 0


def cmd_doctor_notify() -> int:
    run = subprocess.run([sys.executable, str(Path(__file__).resolve()), "doctor"],
                         capture_output=True, text=True, cwd=ROOT)
    report = run.stdout + run.stderr
    (ROOT / ".cache").mkdir(exist_ok=True)
    stamp = time.strftime("%Y-%m-%d %H:%M")
    (ROOT / ".cache" / "doctor-report.txt").write_text(f"{stamp}\n\n{report}", encoding="utf-8")
    if run.returncode != 0:
        subprocess.run(["osascript", "-e",
                        'display notification "red state — see .cache/doctor-report.txt" '
                        'with title "brain doctor"'], capture_output=True)
    return run.returncode


def cmd_doctor() -> int:
    print("brain doctor\n")
    ok = True

    hooks = git("config", "core.hooksPath") == ".githooks"
    if hooks:
        print("  [ok ] git hooks installed")
    else:
        # Must flip ok: with the commit gate off, secrets and malformed notes
        # commit freely. A RED line that still exits 0 means the scheduled
        # watchdog (which only notifies on non-zero exit) never fires.
        ok = False
        print("  [RED] git hooks not installed — run any bin/brain command to fix")

    remote = git("remote", "get-url", "origin")
    if remote and is_local_remote(remote):
        # A "remote" that is a directory on this machine is not a backup, and
        # post-commit deliberately refuses to push to it (cloning your brain to
        # experiment would otherwise push the experiments back into the real
        # one). Say so plainly rather than printing a reassuring [ok].
        ok = False
        print(f"  [RED] remote is a local path ({remote}) — this is NOT an "
              "off-machine backup, and auto-push is disabled for it. Set a real "
              "remote: git remote set-url origin <url>")
    elif remote:
        print(f"  [ok ] remote: {remote}")
        has_upstream = subprocess.run(
            ["git", "rev-parse", "--abbrev-ref", "@{u}"],
            cwd=ROOT, capture_output=True).returncode == 0
        if not has_upstream:
            ok = False
            print("  [RED] no upstream tracking — backup state unknown; run: "
                  "git push -u origin main")
        else:
            unpushed = git("rev-list", "--count", "@{u}..HEAD")
            if unpushed and unpushed != "0":
                ok = False
                print(f"  [RED] {unpushed} commit(s) not pushed — backup is behind; run: git push")
            else:
                print("  [ok ] all commits pushed to remote")
    else:
        ok = False
        print("  [RED] no git remote — knowledge is not backed up")

    dirty = [l for l in git("status", "--porcelain", "knowledge").splitlines() if l.strip()]
    if dirty:
        print(f"  [RED] {len(dirty)} uncommitted change(s) in knowledge/ — commit soon; "
              "uncommitted notes are unvetted and unbacked")
        ok = False
    else:
        print("  [ok ] knowledge/ fully committed")

    import shutil
    for tool, why in (("gitleaks", "second secret scanner at commit time"),
                      ("age", "vault encryption for sensitive notes")):
        if shutil.which(tool):
            print(f"  [ok ] {tool} installed")
        else:
            print(f"  [-- ] {tool} not installed ({why}) — brew install {tool}")

    if INDEX_DB.exists():
        print("  [-- ] search index is stale — refreshes automatically on next search"
              if index_stale() else "  [ok ] search index fresh")
    else:
        print("  [-- ] no search index yet — built automatically on first search")

    inbox_items = sorted((K / "inbox").glob("*.md"), key=lambda p: p.stat().st_mtime)
    if inbox_items:
        oldest_days = int((time.time() - inbox_items[0].stat().st_mtime) / 86400)
        state = "RED" if (len(inbox_items) > 25 or oldest_days > 21) else "ok "
        if state == "RED":
            ok = False
        print(f"  [{state}] inbox backlog: {len(inbox_items)} item(s), oldest {oldest_days}d — "
              "drain via bin/brain consolidate")
    else:
        print("  [ok ] inbox empty")

    # The inbox only drains if consolidation actually runs. Worth its own line
    # because a missing consolidate job is otherwise invisible: every other
    # check stays green while captures pile up with nowhere to go.
    if (PLIST_DIR / f"{SCHEDULES['consolidate']}.plist").exists():
        print("  [ok ] weekly consolidation scheduled")
    else:
        print("  [-- ] weekly consolidation not scheduled — generous capture has no "
              "outlet; bin/brain schedule install --with-consolidate")

    today_iso = date.today().isoformat()
    _meta = MetaIndex()
    try:
        overdue = _meta.overdue(today_iso)
    finally:
        _meta.close()
    if overdue:
        print(f"  [-- ] {len(overdue)} note(s) past review_by — verify them during consolidation")

    stale_branches = git("branch", "--no-merged", "main", "--list", "consolidate/*")
    if stale_branches:
        ok = False
        print(f"  [RED] unreviewed consolidation branch(es): "
              f"{', '.join(b.strip() for b in stale_branches.splitlines())} — review and merge")

    print()
    lint_code = lint()
    return 0 if (ok and lint_code == 0) else 1


def main() -> int:
    argv = sys.argv[1:]
    # --root is INTERNAL: only `lint --staged` re-invokes itself with it to lint
    # an alternate tree. Honoring it for any command turned a user searching for
    # the literal text "--root" into a silent rebind of the repo root (and, for
    # capture, a write outside the brain). Gate it to the lint subcommand.
    if argv[:1] == ["lint"] and "--root" in argv:
        i = argv.index("--root")
        global ROOT, K, INDEX_DB
        ROOT = Path(argv[i + 1]).resolve()
        K = ROOT / "knowledge"
        INDEX_DB = ROOT / ".cache" / "index.db"
        argv = argv[:i] + argv[i + 2:]
    else:
        ensure_hooks()
    if not argv:
        print(__doc__)
        return 2
    cmd, rest = argv[0], argv[1:]
    if cmd == "lint":
        try:
            return lint(staged_only="--staged" in rest)
        except Exception as exc:  # environment failure must not look like content failure
            print(f"brain lint: environment failure: {exc!r}")
            return 3
    if cmd == "init":
        return cmd_init(rest)
    if cmd == "new":
        return cmd_new(rest)
    if cmd == "capture":
        return cmd_capture(rest)
    if cmd == "doctor":
        return cmd_doctor()
    if cmd == "doctor-notify":
        return cmd_doctor_notify()
    if cmd == "index":
        return cmd_index(quiet="--quiet" in rest)
    if cmd == "search":
        return cmd_search(rest)
    if cmd == "read":
        return cmd_read(rest)
    if cmd == "links":
        return cmd_links(rest)
    if cmd == "recent":
        return cmd_recent(rest)
    if cmd == "supersede":
        return cmd_supersede(rest)
    if cmd == "sessions":
        return cmd_sessions(rest)
    if cmd == "consolidate":
        return cmd_consolidate(rest)
    if cmd == "schedule":
        return cmd_schedule(rest)
    if cmd == "template":
        return cmd_template(rest)
    print(f"unknown command {cmd!r}\n{__doc__}")
    return 2


if __name__ == "__main__":
    sys.exit(main())
